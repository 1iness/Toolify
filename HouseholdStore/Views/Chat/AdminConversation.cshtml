@model List<HouseholdStore.Models.ChatMessageVm>
@{
    ViewData["Title"] = "Диалог";
    Layout = null;
    var conversations = ViewBag.Conversations as List<HouseholdStore.Models.ChatConversationVm> ?? new List<HouseholdStore.Models.ChatConversationVm>();
    var selected = ViewBag.SelectedConversation as HouseholdStore.Models.ChatConversationVm;
    var userEmailMap = ViewBag.UserEmailMap as Dictionary<int, string> ?? new Dictionary<int, string>();

    string GetConversationPerson(HouseholdStore.Models.ChatConversationVm? c)
    {
        if (c == null) return "клиентом";

        if (c.UserId.HasValue)
        {
            return userEmailMap.TryGetValue(c.UserId.Value, out var email) && !string.IsNullOrWhiteSpace(email)
                ? email
                : $"Пользователь {c.UserId.Value}";
        }

        if (!string.IsNullOrWhiteSpace(c.GuestEmail))
        {
            return $"Гостем ({c.GuestEmail})";
        }

        return "Гостем";
    }

    string GetListLabel(HouseholdStore.Models.ChatConversationVm c)
    {
        if (c.UserId.HasValue)
        {
            return userEmailMap.TryGetValue(c.UserId.Value, out var email) && !string.IsNullOrWhiteSpace(email)
                ? email
                : $"User {c.UserId.Value}";
        }

        if (!string.IsNullOrWhiteSpace(c.GuestEmail))
        {
            return $"Гость {c.GuestEmail}";
        }

        return !string.IsNullOrWhiteSpace(c.GuestId) ? $"Гость {c.GuestId}" : "Гость";
    }
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
<link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
<link rel="stylesheet" href="~/css/chat-admin-conversation.css" asp-append-version="true" />

@using System.Text.RegularExpressions
@using System.Text.Encodings.Web
@using System.Globalization

@functions {
    private static string MessageToHtml(string? text)
    {
        var encoded = HtmlEncoder.Default.Encode((text ?? string.Empty).Trim());
        return Regex.Replace(
            encoded,
            @"(https?:\/\/[^\s<]+)",
            "<a href=\"$1\" target=\"_blank\" rel=\"noopener noreferrer\">$1</a>",
            RegexOptions.IgnoreCase
        );
    }
}

<div class="chat-admin-page">
    <a class="btn btn-outline-secondary mb-3" href="@Url.Action("Admin", "Chat")">Назад к списку</a>
    <div class="chat-shell">
        <div class="chat-list list-group">
            @foreach (var c in conversations)
            {
                <a href="@Url.Action("AdminConversation", "Chat", new { id = c.Id })"
                   class="list-group-item list-group-item-action @(selected?.Id == c.Id ? "active" : "")">
                    <div class="fw-semibold">#@c.Id - @c.Subject</div>
                    <small>@GetListLabel(c)</small>
                </a>
            }
        </div>
        <div class="chat-main">
            <div class="chat-main-header">
                <h5 class="mb-0">Чат с @GetConversationPerson(selected)</h5>
                @if (!string.IsNullOrWhiteSpace(selected?.Subject))
                {
                    <small class="text-muted">@selected.Subject</small>
                }
            </div>
            <div class="chat-messages" id="chatAdminMessages">
                @{
                    DateTime? previousDay = null;
                }
                @foreach (var m in Model.OrderBy(x => x.CreatedAt))
                {
                    var localTime = m.CreatedAt.ToLocalTime();
                    var messageDay = localTime.Date;
                    if (previousDay == null || previousDay.Value != messageDay)
                    {
                        <div class="chat-day-divider"><span>@localTime.ToString("d MMMM", CultureInfo.GetCultureInfo("ru-RU"))</span></div>
                        previousDay = messageDay;
                    }

                    <div class="msg-row @(m.SenderType == "admin" ? "admin" : "user")">
                        <div class="msg @(m.SenderType == "admin" ? "admin" : "user")">
                            <div class="msg-text">@Html.Raw(MessageToHtml(m.MessageText))</div>
                            <div class="msg-time">@localTime.ToString("HH:mm")</div>
                        </div>
                    </div>
                }
            </div>
            <form method="post" asp-action="AdminReply" asp-controller="Chat" class="reply-form">
                <input type="hidden" name="conversationId" value="@selected?.Id" />
                <textarea class="form-control" name="messageText" rows="2" placeholder="Введите ответ..." required></textarea>
                <button class="btn btn-success" type="submit">Отправить</button>
            </form>
        </div>
    </div>
</div>

<script>
    const box = document.getElementById("chatAdminMessages");
    if (box) box.scrollTop = box.scrollHeight;
</script>
