@model List<HouseholdStore.Models.ChatConversationVm>
@{
    ViewData["Title"] = "Чаты с клиентами";
    Layout = "_AdminLayout";
    var userEmailMap = ViewBag.UserEmailMap as Dictionary<int, string>
                       ?? new Dictionary<int, string>();

    string GetConversationPerson(HouseholdStore.Models.ChatConversationVm c)
    {
        if (c.UserId.HasValue)
            return userEmailMap.TryGetValue(c.UserId.Value, out var e) && !string.IsNullOrWhiteSpace(e)
                ? e : $"Пользователь {c.UserId.Value}";
        if (!string.IsNullOrWhiteSpace(c.GuestEmail))
            return $"Гость · {c.GuestEmail}";
        return !string.IsNullOrWhiteSpace(c.GuestId) ? $"Гость · {c.GuestId}" : "Гость";
    }

    string GetAvatarLetter(HouseholdStore.Models.ChatConversationVm c)
    {
        var person = GetConversationPerson(c);
        return person.Length > 0 ? person[0].ToString().ToUpper() : "?";
    }

    bool IsGuest(HouseholdStore.Models.ChatConversationVm c)
        => !c.UserId.HasValue;
}

<div class="chat-admin-page py-2">

    <div class="chat-page-header">
        <div>

            <div class="chat-page-subtitle">
                @Model.Count диалог@(Model.Count == 1 ? "" : Model.Count is >= 2 and <= 4 ? "а" : "ов")
                · @Model.Count(c => c.HasUnreadForAdmin) непрочитанных
            </div>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="chat-list-card">
            <div class="chat-empty">
                <i class="bi bi-chat-square-text"></i>
                <p>Пока нет обращений в чат</p>
            </div>
        </div>
    }
    else
    {
        <div class="chat-list-card">
            @foreach (var c in Model.OrderByDescending(x => x.LastMessageAt))
            {
                var person = GetConversationPerson(c);
                var letter = GetAvatarLetter(c);
                var isGuest = IsGuest(c);

                <a href="@Url.Action("AdminConversation", "Chat", new { id = c.Id })"
                   class="chat-list-item">

                    <div class="chat-avatar @(isGuest ? "guest" : "")">
                        @letter
                    </div>

                    <div class="chat-item-body">
                        <div class="chat-item-subject">#@c.Id · @c.Subject</div>
                        <div class="chat-item-person">
                            <i class="bi @(isGuest ? "bi-person-dash" : "bi-person-check")"
                               style="margin-right:4px;"></i>@person
                        </div>
                        <div class="chat-item-preview">@c.LastMessagePreview</div>
                    </div>

                    <div class="chat-item-meta">
                        <span class="chat-item-time">
                            @c.LastMessageAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")
                        </span>
                        @if (c.HasUnreadForAdmin)
                        {
                            <span class="badge-unread">
                                <i class="bi bi-circle-fill" style="font-size:8px;"></i> Новые
                            </span>
                        }
                        else
                        {
                            <span style="font-size:12px; color:#ccc;">
                                <i class="bi bi-check2-all"></i>
                            </span>
                        }
                    </div>

                </a>
            }
        </div>
    }
</div>
