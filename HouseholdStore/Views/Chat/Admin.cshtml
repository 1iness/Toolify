@model List<HouseholdStore.Models.ChatConversationVm>
@{
    ViewData["Title"] = "Чаты с клиентами";
    Layout = null;
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
<div class="container py-4">
    <h2 class="mb-4">Чаты с клиентами</h2>

    @if (!Model.Any())
    {
        <div class="alert alert-info">Пока нет обращений в чат.</div>
    }
    else
    {
        <div class="list-group">
            @foreach (var c in Model)
            {
                <a href="@Url.Action("AdminConversation", "Chat", new { id = c.Id })" class="list-group-item list-group-item-action">
                    <div class="d-flex w-100 justify-content-between align-items-center">
                        <div>
                            <h6 class="mb-1">#@c.Id - @c.Subject</h6>
                            <small class="text-muted">
                                @(c.UserId.HasValue ? $"Пользователь ID: {c.UserId}" : $"Гость: {c.GuestId}")
                                @if (!string.IsNullOrWhiteSpace(c.GuestEmail))
                                {
                                    <span> | Email: @c.GuestEmail</span>
                                }
                            </small>
                            <div class="text-truncate mt-1">@c.LastMessagePreview</div>
                        </div>
                        <div class="text-end">
                            <small class="text-muted d-block">@c.LastMessageAt.ToLocalTime()</small>
                            @if (c.HasUnreadForAdmin)
                            {
                                <span class="badge text-bg-danger mt-1">Новые</span>
                            }
                        </div>
                    </div>
                </a>
            }
        </div>
    }
</div>
