@model List<Toolify.ProductService.Models.Product>

@{
    ViewData["Title"] = "Каталог товаров";

    var cat = ViewBag.SelectedCategory as string;
    var sort = ViewBag.SelectedSort as string;
    var min = ViewBag.MinPrice as decimal?;
    var max = ViewBag.MaxPrice as decimal?;
}

<partial name="_Breadcrumbs" />
<div class="catalog-page-container">

    <aside class="catalog-sidebar">
       <form method="get" action="@Url.Action("Catalog", "Home")" id="filterForm">
        <input type="hidden" name="CategoryId" value="@ViewBag.CategoryId" />
        <input type="hidden" name="SpecialCategory" value="@ViewBag.SpecialCategory" />
        <input type="hidden" name="Sort" value="@ViewBag.SelectedSort" />

        <div class="filter-group">
            <h3>Цена, Руб</h3>
            <div class="price-inputs">
                <div class="input-wrapper">
                    <span>от</span>
                    <input type="number" name="minPrice" value="@min" placeholder="0" min="0">
                </div>
                <div class="input-wrapper">
                    <span>до</span>
                    <input type="number" name="maxPrice" value="@max" placeholder="99999" min="0">
                </div>
            </div>
        </div>

        @if (ViewBag.CategoryFilters != null)
        {
            var filters = (List<Toolify.ProductService.Models.CategoryFilterDto>)ViewBag.CategoryFilters;
            foreach (var f in filters)
            {
                <div class="filter-group">
                    <h3>@f.FeatureName</h3>
                    <div class="checkbox-options" style="max-height: 200px; overflow-y: auto;">
                            @foreach (var val in f.AvailableValues)
                            {
                                bool isChecked = ViewBag.SelectedFeatures != null &&
                                ViewBag.SelectedFeatures.ContainsKey(f.FeatureId) &&
                                ViewBag.SelectedFeatures[f.FeatureId].Contains(val);

                                <label style="display: block; margin-bottom: 5px; cursor: pointer;">
                                    <input type="checkbox"
                                           name="SelectedFeatures[@f.FeatureId]"
                                           value="@val"
                                           @(isChecked ? "checked" : "") />
                                    @val
                                </label>
                            }
                    </div>
                </div>
            }
        }

        <button type="submit" class="btn-apply-filters" style="margin-top: 20px;">Показать товары</button>
    </form>
    </aside>


    <main class="catalog-content">

        <div class="catalog-top-bar">
            <span class="products-count">Найдено: @Model.Count товаров</span>

            <div class="sort-wrapper">
                <span>Сортировать по:</span>
                <select id="sortSelect" onchange="submitSort(this.value)">
                    <!option value="" @(string.IsNullOrEmpty(sort) ? "selected" : "")>По умолчанию</!option>
                    <!option value="price_asc" @(sort == "price_asc" ? "selected" : "")>Сначала дешевые</!option>
                    <!option value="price_desc" @(sort == "price_desc" ? "selected" : "")>Сначала дорогие</!option>
                    <!option value="name" @(sort == "name" ? "selected" : "")>По названию (А-Я)</!option>
                    <!option value="rating" @(sort == "rating" ? "selected" : "")>По рейтингу</!option>
                </select>
            </div>
        </div>

        @if (Model.Any())
        {
            <div id="catalog-grid" class="products-grid">
                @foreach (var product in Model)
                {
                    bool hasDiscount = product.Discount > 0;
                    bool isOutOfStock = product.StockQuantity <= 0;
                    decimal finalPrice = product.Price;
                    if (hasDiscount)
                    {
                        finalPrice = product.Price - (product.Price * product.Discount / 100m);
                    }
                    <div class="product-card catalog-item" style="display:none; position:relative; flex-direction:column; height:100%; justify-content:space-between;">

                        <div class="card-top">
                            @if (hasDiscount)
                            {
                                <span class="badge discount">-@product.Discount%</span>
                            }
                        </div>

                        <a href="@Url.Action("Details", "Home", new { id = product.Id })" style="text-decoration:none; color:inherit;">
                            <div style="height:200px; display:flex; align-items:center; justify-content:center; overflow:hidden; margin-bottom:10px;">
                                <img src="/api/Product/@product.Id/image" alt="@product.Name" style="max-height:100%; max-width:100%; object-fit:contain;" onerror="this.onerror=null; this.src='/image/no-image.png';" />
                            </div>
                        </a>

                        <div class="price-block" style="margin-top: 10px; margin-bottom: 5px;">
                            <span class="price @(hasDiscount ? "price--sale" : "")">
                                @finalPrice.ToString("N2") <span class="price-currency">руб.</span>
                            </span>
                            @if (hasDiscount)
                            {
                                <span class="price-old" style="text-decoration: line-through; color: #999; font-size: 14px; margin-left: 8px;">
                                    @product.Price.ToString("N2") руб.
                                </span>
                            }
                        </div>

                        <div class="rating-stars" style="margin-bottom:10px; display:flex; align-items:center; flex-wrap:wrap;">
                            @{
                                var ratings = ViewBag.ProductRatings as Dictionary<int, double>;
                                double rating = ratings != null && ratings.ContainsKey(product.Id) ? ratings[product.Id] : product.AverageRating;
                            }
                            @for (int i = 1; i <= 5; i++)
                            {
                                if (rating >= i)
                                {
                                    <i class="bi bi-star-fill" style="color:#ffc107;"></i>
                                }
                                else if (rating >= i - 0.5)
                                {
                                    <i class="bi bi-star-half" style="color:#ffc107;"></i>
                                }
                                else
                                {
                                    <i class="bi bi-star" style="color:#ccc;"></i>
                                }
                            }
                            <span style="color:#999; font-size:12px; margin-left:8px;">@rating.ToString("0.0") (@product.ReviewsCount отзывов)</span>
                        </div>

                        <h3 class="title" style="font-size:16px; font-weight:500; margin:0 0 6px 0; min-height:auto;">@product.Name</h3>
                        <span style="font-weight: normal; font-size: 0.85em; color: #777;">арт. @product.ArticleNumber</span>

                        <div style="margin-top:auto;">
                            @if (isOutOfStock)
                            {
                                <div class="stock out">Нет в наличии</div>
                                <button type="button" class="btn-buy disabled" disabled>Скоро будет</button>
                            }
                            else
                            {
                                <div class="stock in">В наличии: @product.StockQuantity шт.</div>
                                <a href="javascript:void(0)" onclick="addToCartAnimated(event, @product.Id, this)" class="btn-buy">
                                    <i class="bi bi-cart-plus"></i> В корзину
                                </a>
                            }
                        </div>
                    </div>
                }
            </div>

            <div style="text-align:center; margin-top:30px;">
                <button id="load-more-btn" class="btn-add-cart" style="width:auto; padding:12px 40px; display:none;">
                    Показать ещё
                </button>
            </div>
        }
        else
        {
            <div class="no-products">
                <i class="bi bi-search" style="font-size: 40px; color: #ccc;"></i>
                <p>Товары не найдены. Попробуйте изменить фильтры.</p>
            </div>
        }
    </main>
</div>

<script>
    function submitSort(value) {
        var form = document.getElementById('filterForm');
        var sortInput = form.querySelector('input[name="sort"]');
        sortInput.value = value;
        form.submit();
    }

    (function () {
        const BATCH = 9;  
        const items = Array.from(document.querySelectorAll('.catalog-item'));
        const btn = document.getElementById('load-more-btn');
        let shown = 0;

        function showMore() {
            const next = shown + BATCH;
            items.slice(shown, next).forEach(el => el.style.display = 'flex');
            shown = next;
            btn.style.display = shown >= items.length ? 'none' : 'inline-block';
        }

        btn.addEventListener('click', showMore);
        showMore();
    })();

</script>