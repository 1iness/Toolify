@model Toolify.ProductService.Models.Product

@{
    ViewData["Title"] = Model.Name;
    ViewData["ParentPage"] = "Каталог";
    ViewData["ParentLink"] = "/Home/Index";

    bool hasDiscount = Model.Discount > 0;
    bool isOutOfStock = Model.StockQuantity <= 0;
    decimal finalPrice = Model.Price;
    if (hasDiscount)
    {
        finalPrice = Model.Price - (Model.Price * Model.Discount / 100);
    }
}

<partial name="_Breadcrumbs" />
<div class="product-details-container">

    <div class="detail-image">
        <img src="https://localhost:7188/api/Product/@(Model.Id)/image"
             alt="@Model.Name"
             style="width: 85%; max-height: 500px; object-fit: contain;"
             onerror="this.onerror=null; this.src='/image/no-image.png';" />
    </div>

    @{
        var reviews = ViewBag.Reviews as List<HouseholdStore.Models.ReviewViewModel> ?? new List<HouseholdStore.Models.ReviewViewModel>();
        var avgRating = (double)(ViewBag.AverageRating ?? 0);
        var reviewsCount = (int)(ViewBag.ReviewsCount ?? 0);
        var starCounts = ViewBag.StarCounts as int[] ?? new int[6];
    }

    <div class="detail-info">
        <h1 class="detail-title">@Model.Name</h1>

        <div class="detail-rating-row">
            <span class="stars">★</span>
            
            <span class="rating-value">@avgRating.ToString("0.0") </span>
            <span class="reviews-count">(@reviewsCount отзывов)</span>
            <span style="margin-left: 20px; color: #666; font-size: 0.9em;">
                Артикул: @Model.ArticleNumber
            </span>
        </div>

        <div class="action-buttons-row">
            @if (User.Identity != null && User.Identity.IsAuthenticated)
            {
                <button class="btn-favourite btn-text-icon"
                        data-product-id="@Model.Id"
                        data-is-fav="@ViewBag.IsFavourite.ToString().ToLower()">
                    <i class="@(ViewBag.IsFavourite ? "bi bi-heart-fill" : "bi bi-heart")"
                       style="font-size:20px; color:@(ViewBag.IsFavourite ? "#ff4d4f" : "currentColor");"></i>
                    <span>@(ViewBag.IsFavourite ? "В избранном" : "В избранное")</span>
                </button>
            }
            else
            {
                <a href="/Account/Login" class="btn-text-icon" title="Войдите чтобы добавить в избранное">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
                    </svg>
                    В избранное
                </a>
            }

            <button class="btn-text-icon">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="18" y1="20" x2="18" y2="10"></line>
                    <line x1="12" y1="20" x2="12" y2="4"></line>
                    <line x1="6" y1="20" x2="6" y2="14"></line>
                </svg>
                Сравнить
            </button>
        </div>

        <div class="detail-description">
            <h3>Описание</h3>
            <p>@Model.FullDescription</p>
        </div>
        @if (Model.Configurations != null && Model.Configurations.Any())
        {
            <div class="detail-characteristics" style="margin-top: 30px;">
                <h3 style="font-size: 18px; margin-bottom: 15px;">Характеристики</h3>
                <table class="characteristics-table">
                    <tbody>
                        @foreach (var config in Model.Configurations)
                        {
                            <tr>
                                <td class="char-name">
                                    <span>@config.FeatureName</span>
                                </td>
                                <td class="char-value">
                                    @config.FeatureValue
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>

   

    <div class="detail-buy-block product-card">
        <div class="price-wrap">
            <span class="main-price">@finalPrice.ToString("N2") Руб</span>
            @if (hasDiscount)
            {
                <span class="old-price">@Model.Price.ToString("N2") Руб</span>
                <span class="badge discount">-@Model.Discount%</span>
            }
        </div>

        @if (isOutOfStock)
        {
            <div class="stock out">Нет в наличии</div>
            <button class="btn-add-cart disabled" disabled>Нет в наличии</button>
        }
        else
        {
            <div class="stock in">В наличии</div>
            <button type="button"
                    class="btn-add-cart"
                    onclick="addToCartAnimated(event, @Model.Id, this)">
                Добавить в корзину
            </button>
        }
    </div>
</div>


<div class="reviews-container">

    <div class="reviews-left-column">
        <h2 class="reviews-title">Отзывы о товаре (@reviewsCount)</h2>

        @if (!reviews.Any())
        {
            <p style="color: #777; margin-bottom: 20px;">Отзывов пока нет. Будьте первым!</p>
        }
        else
        {
            <div class="reviews-preview-wrapper">
                <div class="review-list">
                    @foreach (var review in reviews.Take(3))
                    {
                        <div class="review-item">
                            <div class="review-header">
                                <div class="user-avatar" aria-hidden="true">
                                    @(string.IsNullOrWhiteSpace(review.UserName) ? "?" : review.UserName.Trim().Substring(0, 1).ToUpperInvariant())
                                </div>
                                <div class="review-header-main">
                                    <span class="user-name">@review.UserName</span>
                                    <div class="stars-green" aria-label="Оценка @review.Rating.ToString("0.0") из 5">
                                        <partial name="_ReviewStars" model="review.Rating" />
                                    </div>
                                </div>
                                <span class="review-date">@review.CreatedAt.ToString("dd.MM.yyyy")</span>
                            </div>
                            <div class="review-body">
                                @if (!string.IsNullOrEmpty(review.Pros))
                                {
                                    <div class="review-snippet review-snippet--pros">
                                        <div class="review-snippet-label">Достоинства</div>
                                        <p>@review.Pros</p>
                                    </div>
                                }
                                @if (!string.IsNullOrEmpty(review.Cons))
                                {
                                    <div class="review-snippet review-snippet--cons">
                                        <div class="review-snippet-label">Недостатки</div>
                                        <p>@review.Cons</p>
                                    </div>
                                }
                                @if (!string.IsNullOrEmpty(review.Comment))
                                {
                                    <div class="review-comment">
                                        <div class="review-comment-label">Комментарий</div>
                                        <p>@review.Comment</p>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                </div>

                @if (reviewsCount > 3)
                {
                    <div class="reviews-fade-overlay"></div>
                }
            </div>

            @if (reviewsCount > 3)
            {
                <div style="text-align: center; margin-top: 20px;">
                    <a asp-action="AllReviews" asp-route-productId="@Model.Id" class="btn-view-all-reviews">
                        Смотреть все отзывы (@reviewsCount)
                    </a>
                </div>
            }
        }
    </div>

    <div class="reviews-right-column">
        <div class="rating-card">
            <h3 class="rating-title">Рейтинг покупателей</h3>

            <div class="rating-main-row">
                <div class="stars-green big" style="color: #28a745;">
                    @for (int i = 1; i <= 5; i++)
                    {
                        if (avgRating >= i)
                        {
                            <i class="bi bi-star-fill"></i> 
                        }
                        else if (avgRating >= (i - 0.5))
                        {
                            <i class="bi bi-star-half"></i> 
                        }
                        else
                        {
                            <i class="bi bi-star"></i> 
                        }
                    }
                </div>
                <div class="rating-score">@avgRating.ToString("0.0") <span>/ 5</span></div>
            </div>

            <div class="rating-bars">
                @for (int i = 5; i >= 1; i--)
                {
                    var count = starCounts[i];
                    var percent = reviewsCount > 0 ? (double)count / reviewsCount * 100 : 0;
                    <div class="bar-row">
                        <span class="star-label">@i звезд</span>
                        <div class="progress-track">
                            <div class="progress-fill" style="width: @percent.ToString("0")%;"></div>
                        </div>
                        <span class="percent-label">@percent.ToString("0")%</span>
                    </div>
                }
            </div>

            <button class="btn-leave-review" onclick="openReviewModal()">
                Оставить свой отзыв
            </button>
        </div>
    </div>
</div>

<div id="reviewModal" class="modal-overlay">
    <div class="review-modal">
        <button class="modal-close" onclick="closeReviewModal()">×</button>
        <h3 class="modal-title">Ваш отзыв</h3>

        <form asp-controller="Home" asp-action="LeaveReview" method="post">
            <input type="hidden" name="ProductId" value="@Model.Id" />

            <div class="form-group" style="text-align: center;">
                <label class="form-label">Общая оценка</label>
                <input type="hidden" name="Rating" id="ratingInput" value="5" />
                <div class="star-rating-input" id="starContainer">
                    @for (int i = 1; i <= 5; i++)
                    {
                        var halfVal = (i - 0.5).ToString("0.0", System.Globalization.CultureInfo.InvariantCulture);
                        <span class="star-wrap" data-full="@i" data-half="@halfVal">
                            <svg class="star-svg" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                                <defs>
                                    <clipPath id="half-clip-@i">
                                        <rect x="0" y="0" width="12" height="24" />
                                    </clipPath>
                                </defs>
                                <!-- серая звезда (фон) -->
                                <polygon class="star-bg"
                                         points="12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26"
                                         fill="#ddd" stroke="none" />
                                <!-- жёлтая половина -->
                                <polygon class="star-half"
                                         points="12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26"
                                         fill="#ffc107" stroke="none"
                                         clip-path="url(#half-clip-@i)"
                                         style="display:none;" />
                                <!-- жёлтая полная -->
                                <polygon class="star-full"
                                         points="12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26"
                                         fill="#ffc107" stroke="none"
                                         style="display:none;" />
                            </svg>
                            <!-- зоны нажатия -->
                            <span class="star-zone-left" data-value="@halfVal"></span>
                            <span class="star-zone-right" data-value="@i"></span>
                        </span>
                    }
                </div>
            </div>

            <div class="form-group">
                <label class="form-label">Достоинства</label>
                <input type="text" name="Pros" class="form-input" placeholder="Что вам понравилось" />
            </div>

            <div class="form-group">
                <label class="form-label">Недостатки</label>
                <input type="text" name="Cons" class="form-input" placeholder="Что не оправдало ожиданий" />
            </div>

            <div class="form-group">
                <label class="form-label">Комментарий</label>
                <textarea name="Comment" class="form-textarea" placeholder="Другие впечатления"></textarea>
            </div>

            <div class="user-row">
                <div class="form-group">
                    <label class="form-label">Как вас зовут</label>
                    <input type="text" name="UserName" class="form-input" required
                           value="@(User.Identity.IsAuthenticated? User.Identity.Name : "")" />
                </div>
                <div class="form-group">
                    <label class="form-label">Ваш e-mail</label>
                    <input type="email" name="UserEmail" class="form-input" required
                           value="@(User.Identity.IsAuthenticated? User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value : "")" />
                </div>
            </div>

            <button type="submit" class="btn-submit-review">Отправить отзыв</button>
        </form>
    </div>
</div>

@section Scripts {
    <script src="~/js/product-reviews.js" asp-append-version="true"></script>
    <script src="~/js/product-favorite.js" asp-append-version="true"></script>
}