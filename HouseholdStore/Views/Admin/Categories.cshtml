@model List<Toolify.ProductService.Models.CategoryAdminItem>
@{
    ViewData["Title"] = "Категории";
    Layout = "_AdminLayout";
}
<link rel="stylesheet" href="~/css/site.css" />

<div class="admin-flush-page" data-admin-heading="Категории">
    <h1 class="visually-hidden">Категории</h1>
    @if (TempData["CategoryMessage"] != null)
    {
        <p class="text-success mb-2">@TempData["CategoryMessage"]</p>
    }
    @if (TempData["CategoryError"] != null)
    {
        <p class="text-danger mb-2">@TempData["CategoryError"]</p>
    }
    <div class="admin-products-list-toolbar">
        <div class="admin-products-list-actions">
            <a href="/Admin/Create" class="btn-create">Добавить товар</a>
            <a href="/Admin/List" class="btn-create btn-create--secondary">К списку товаров</a>
        </div>
    </div>

    <div class="admin-products-table-wrap">
    <table class="admin-table admin-table--products">
        <thead>
            <tr>
                <th>Id</th>
                <th>Название</th>
                <th>Товаров</th>
                <th>Иконка</th>
                <th>Действия</th>
            </tr>
        </thead>
        <tbody>
        @if (Model != null && Model.Count > 0)
        {
            foreach (var c in Model)
            {
                <tr>
                    <td>@c.Id</td>
                    <td><strong>@c.Name</strong></td>
                    <td>@c.ProductCount</td>
                    <td style="min-width: 200px; vertical-align: top;">
                        @if (!string.IsNullOrEmpty(c.IconFileName))
                        {
                            <div><img src="~/image/category-icons/@c.IconFileName" alt="" style="max-height: 44px; object-fit: contain;" /></div>
                        }
                        else
                        {
                            <span style="color:#999;">—</span>
                        }
                        <form asp-action="UploadCategoryIcon" method="post" enctype="multipart/form-data" style="margin-top:8px;">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@c.Id" />
                            <input type="file" name="iconFile" accept=".png,.jpg,.jpeg,.webp,.gif" style="max-width: 180px; font-size: 12px;" />
                            <button type="submit" class="btn-create" style="font-size: 12px; padding: 4px 10px; margin-top: 4px;">Сохранить</button>
                        </form>
                    </td>
                    <td>
                        @if (c.ProductCount == 0)
                        {
                            <form asp-action="DeleteCategory" method="post" style="display:inline;" onsubmit="return confirm('Удалить эту категорию?');">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@c.Id" />
                                <button type="submit" class="delete-link" style="border:none;background:none;cursor:pointer;padding:0;color:#c00;text-decoration:underline;">Удалить</button>
                            </form>
                        }
                        else
                        {
                            <span style="color:#999;">—</span>
                        }
                    </td>
                </tr>
            }
        }
        else
        {
            <tr><td colspan="5">Категорий нет.</td></tr>
        }
        </tbody>
    </table>
    </div>
</div>
