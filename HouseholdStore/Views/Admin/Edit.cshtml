@model Toolify.ProductService.Models.Product

@{
    ViewData["Title"] = "Редактировать товар";
    Layout = null;
}

<link rel="stylesheet" href="~/css/site.css" />

<div style="padding: 20px;">
    <h1>Редактировать товар</h1>

    <form method="post" enctype="multipart/form-data" asp-action="Edit">
        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="ImagePath" />

        <p><b>Категория:</b></p>
        <select asp-for="CategoryId" asp-items="ViewBag.Categories" required style="padding: 5px; width: 200px;">
            <option value="">-- Выберите категорию --</option>
        </select>

        <p><b>Название:</b></p>
        <input type="text" asp-for="Name" required style="width: 300px;" />

        <p><b>Краткое описание:</b></p>
        <input type="text" asp-for="ShortDescription" style="width: 300px;" />

        <p><b>Полное описание:</b></p>
        <textarea asp-for="FullDescription" rows="4" cols="50"></textarea>

        <div id="features-section" style="margin-top: 20px; margin-bottom: 20px; border: 1px solid #eee; padding: 15px; border-radius: 8px; background-color: #f9f9f9;">
            <h3 style="font-size: 16px; margin-bottom: 15px;">Характеристики товара</h3>

            <div id="features-container">
                @if (Model.Configurations != null && Model.Configurations.Any())
                {
                    for (int i = 0; i < Model.Configurations.Count; i++)
                    {
                        var config = Model.Configurations[i];
                        <div class="feature-row" style="display: flex; align-items: center; margin-bottom: 10px;">
                            <div style="flex-grow: 1;">
                                <label style="display:block; font-weight:500;">@config.FeatureName:</label>
                                <input type="hidden" name="Configurations[@i].FeatureId" value="@config.FeatureId" />
                                <input type="hidden" name="Configurations[@i].FeatureName" value="@config.FeatureName" />
                                <input type="text" name="Configurations[@i].FeatureValue" value="@config.FeatureValue"
                                       style="width: 100%; padding: 8px; border: 1px solid #ccc; border-radius: 4px;" />
                            </div>
                            <button type="button" onclick="removeFeature(this)"
                                    style="margin-left: 10px; margin-top: 20px; background: #ff4d4d; color: white; border: none; border-radius: 4px; padding: 5px 10px; cursor: pointer;">
                                ✕
                            </button>
                        </div>
                    }
                }
            </div>

            <button type="button" onclick="addCustomFeature()" style="margin-top: 10px; background: #6c757d; color: white; border: none; padding: 5px 10px; border-radius: 4px; cursor: pointer;">
                + Добавить свое поле
            </button>
        </div>

        <div style="display: flex; gap: 20px;">
            <div>
                <p><b>Цена (₽):</b></p>
                <input type="number" asp-for="Price" step="0.01" required />
            </div>

            <div>
                <p><b>Скидка (%):</b></p>
                <input type="number" asp-for="Discount" min="0" max="100" />
                <br />
                <small style="color: gray;">Укажите 0, чтобы убрать скидку</small>
            </div>
        </div>

        <p><b>Количество на складе:</b></p>
        <input type="number" asp-for="StockQuantity" required />

        <p><b>Текущее изображение:</b></p>
        <div style="min-height: 150px; border: 1px dashed #ccc; padding: 10px; display: inline-block;">
            <img src="https://localhost:7188/api/Product/@(Model.Id)/image"
                 width="150"
                 style="display: block;"
                 onerror="this.onerror=null; this.src='/images/no-image.png';" />

        <p><b>Загрузить новое (если нужно заменить):</b></p>
            <input type="file" name="image" class="form-control" accept="image/*" />

        <br /><br />
        <button type="submit" style="padding: 10px 20px; cursor: pointer;">Сохранить изменения</button>
        <a href="/Admin/Index" style="margin-left: 20px;">Отмена</a>
    </form>
</div>

<script>
    function removeFeature(btn) {
        const row = btn.closest('.feature-row');
        const container = document.getElementById('features-container');
        row.remove();

        const rows = container.querySelectorAll('.feature-row');
        rows.forEach((row, index) => {
            row.querySelectorAll('input').forEach(input => {
                const name = input.getAttribute('name');
                if (name) {
                    input.setAttribute('name', name.replace(/\[\d+\]/, `[${index}]`));
                }
            });
        });
    }

    function addCustomFeature() {
        const container = document.getElementById('features-container');
        const index = container.querySelectorAll('.feature-row').length;

        const div = document.createElement('div');
        div.className = 'feature-row';
        div.style.display = 'flex';
        div.style.alignItems = 'center';
        div.style.marginBottom = '10px';

        div.innerHTML = `
            <div style="flex-grow: 1; display: flex; gap: 10px;">
                <div style="flex-grow: 1;">
                    <label style="display:block; font-weight:500; color:gray;">Название:</label>
                    <input type="text" placeholder="Напр. Вес" name="Configurations[${index}].FeatureName"
                           style="width: 100%; padding: 8px; border: 1px solid #ccc; border-radius: 4px;" required />
                </div>
                <div style="flex-grow: 1;">
                    <label style="display:block; font-weight:500; color:gray;">Значение:</label>
                    <input type="text" placeholder="Напр. 500г" name="Configurations[${index}].FeatureValue"
                           style="width: 100%; padding: 8px; border: 1px solid #ccc; border-radius: 4px;" required />
                </div>
                <input type="hidden" name="Configurations[${index}].FeatureId" value="0" />
            </div>
            <button type="button" onclick="removeFeature(this)"
                    style="margin-left: 10px; margin-top: 20px; background: #ff4d4d; color: white; border: none; border-radius: 4px; padding: 5px 10px; cursor: pointer;">
                ✕
            </button>
        `;
        container.appendChild(div);
    }
</script>