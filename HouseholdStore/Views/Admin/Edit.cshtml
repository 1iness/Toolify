@model Toolify.ProductService.Models.Product

@{
    ViewData["Title"] = "Редактировать товар";
    Layout = null;
}

<link rel="stylesheet" href="~/css/create-product.css" />

<div class="admin-form-wrapper">
    <h1>Редактировать товар</h1>

    <form method="post" enctype="multipart/form-data" asp-action="Edit">
        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="ImagePath" />
        <input type="hidden" asp-for="ArticleNumber">

        <div class="form-group">
            <p><b>Категория:</b></p>
            <select asp-for="CategoryId" asp-items="ViewBag.Categories" required class="form-select" style="max-width: 300px;">
                <option value="">-- Выберите категорию --</option>
            </select>
        </div>

        <div class="form-group">
            <p><b>Название:</b></p>
            <input type="text" asp-for="Name" required class="form-input" />
        </div>

        <div class="form-group">
            <p><b>Краткое описание:</b></p>
            <input type="text" asp-for="ShortDescription" class="form-input" />
        </div>

        <div class="form-group">
            <p><b>Полное описание:</b></p>
            <textarea asp-for="FullDescription" rows="4" class="form-textarea"></textarea>
        </div>

        <div id="features-section" class="features-section">
            <h3 style="font-size: 16px; margin-top: 0; margin-bottom: 15px;">Характеристики товара</h3>

            <div id="features-container">
                @if (Model.Configurations != null && Model.Configurations.Any())
                {
                    for (int i = 0; i < Model.Configurations.Count; i++)
                    {
                        var config = Model.Configurations[i];
                        <div class="feature-row">
                            <div style="flex-grow: 1;">
                                <label style="display:block; font-weight:500; margin-bottom: 5px;">@config.FeatureName:</label>
                                <input type="hidden" name="Configurations[@i].FeatureId" value="@config.FeatureId" />
                                <input type="hidden" name="Configurations[@i].FeatureName" value="@config.FeatureName" />
                                <input type="text" name="Configurations[@i].FeatureValue" value="@config.FeatureValue" class="form-input" />
                            </div>
                            <button type="button" onclick="removeFeature(this)" class="btn btn-danger" style="margin-top: 22px;">✕</button>
                        </div>
                    }
                }
            </div>

            <button type="button" onclick="addCustomFeature()" class="btn btn-secondary" style="margin-top: 10px;">
                + Добавить свое поле
            </button>
        </div>

        <div style="display: flex; gap: 20px; margin-bottom: 15px;">
            <div style="flex: 1;">
                <p><b>Цена (₽):</b></p>
                <input type="number" asp-for="Price" step="0.01" required class="form-input" />
            </div>

            <div style="flex: 1;">
                <p><b>Скидка (%):</b></p>
                <input type="number" asp-for="Discount" min="0" max="100" class="form-input" />
                <small style="color: gray; display: block; margin-top: 4px;">Укажите 0, чтобы убрать скидку</small>
            </div>
        </div>

        <div class="form-group">
            <p><b>Количество на складе:</b></p>
            <input type="number" asp-for="StockQuantity" required class="form-input" style="max-width: 200px;" />
        </div>

        <div class="form-group">
            <p><b>Текущее изображение:</b></p>
            <div style="min-height: 150px; border: 1px dashed #ccc; padding: 15px; border-radius: 8px; display: inline-block; background: #fff;">
                <img src="https://localhost:7188/api/Product/@(Model.Id)/image"
                     width="150"
                     style="display: block; border-radius: 4px;"
                     onerror="this.onerror=null; this.src='/images/no-image.png';" />
            </div>
        </div>

        <div class="form-group">
            <p><b>Загрузить новое (если нужно заменить):</b></p>
            <input type="file" name="image" class="form-input" accept="image/*" style="padding: 7px 15px;" />
        </div>

        <div style="margin-top: 30px;">
            <button type="submit" class="btn btn-primary">Сохранить изменения</button>
            <a href="/Admin/Index" class="btn btn-cancel">Отмена</a>
        </div>
    </form>
</div>

<script>
    function removeFeature(btn) {
        const row = btn.closest('.feature-row');
        const container = document.getElementById('features-container');
        row.remove();

        const rows = container.querySelectorAll('.feature-row');
        rows.forEach((row, index) => {
            row.querySelectorAll('input').forEach(input => {
                const name = input.getAttribute('name');
                if (name) {
                    input.setAttribute('name', name.replace(/\[\d+\]/, `[${index}]`));
                }
            });
        });
    }

    function addCustomFeature() {
        const container = document.getElementById('features-container');
        const index = container.querySelectorAll('.feature-row').length;

        const div = document.createElement('div');
        div.className = 'feature-row';

        div.innerHTML = `
            <div style="flex-grow: 1; display: flex; gap: 15px;">
                <div style="flex-grow: 1;">
                    <label style="display:block; font-size: 12px; color: gray; margin-bottom: 5px;">Название:</label>
                    <input type="text" placeholder="Напр. Вес" name="Configurations[${index}].FeatureName" class="form-input" required />
                </div>
                <div style="flex-grow: 1;">
                    <label style="display:block; font-size: 12px; color: gray; margin-bottom: 5px;">Значение:</label>
                    <input type="text" placeholder="Напр. 500г" name="Configurations[${index}].FeatureValue" class="form-input" required />
                </div>
                <input type="hidden" name="Configurations[${index}].FeatureId" value="0" />
            </div>
            <button type="button" onclick="removeFeature(this)" class="btn btn-danger" style="margin-top: 22px;">✕</button>
        `;
        container.appendChild(div);
    }
</script>