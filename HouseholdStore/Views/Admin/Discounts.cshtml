@model HouseholdStore.Models.AdminDiscountsViewModel
@using Microsoft.AspNetCore.Mvc.Rendering
@using Toolify.ProductService.Models
@using Toolify.AuthService.Models

@{
    ViewData["Title"] = "Акции и скидки";
    Layout = null;
    var catList = ViewBag.Categories as SelectList;
    var userList = ViewBag.Users as SelectList;
    var categoriesList = ViewBag.CategoriesList as List<Category> ?? new List<Category>();
    var usersList = ViewBag.UsersList as List<User> ?? new List<User>();
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">

<div class="container-fluid py-4 px-3" style="max-width: 1400px;">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="h3 mb-0 fw-bold text-dark">Акции и скидки</h2>
        <a href="/Admin/Index" class="btn btn-outline-secondary btn-sm"><i class="fas fa-arrow-left"></i> Назад в панель</a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    <div class="alert alert-info small mb-4">
        <strong>Как это работает.</strong> Акции (кампании) задают период и приоритет; правила привязываются к акции опционально.
        Скидка по категории — процент или фиксированная сумма по сумме товаров этой категории; по клиенту — персональная скидка.
        Минимальная сумма товаров в правиле действует до применения промокода (как в БД). Изменения вступают в силу для новых заказов.
    </div>

    <div class="row g-4">
        <div class="col-lg-5">
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-white fw-semibold">Новая акция (кампания)</div>
                <div class="card-body">
                    <form asp-action="AddDiscountCampaign" method="post">
                        <div class="mb-2">
                            <label class="form-label small mb-0">Название</label>
                            <input type="text" name="name" class="form-control form-control-sm" required maxlength="150" />
                        </div>
                        <div class="mb-2">
                            <label class="form-label small mb-0">Описание</label>
                            <input type="text" name="description" class="form-control form-control-sm" maxlength="500" />
                        </div>
                        <div class="row g-2">
                            <div class="col-md-6">
                                <label class="form-label small mb-0">Начало</label>
                                <input type="datetime-local" name="startDate" class="form-control form-control-sm" required />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label small mb-0">Окончание</label>
                                <input type="datetime-local" name="endDate" class="form-control form-control-sm" required />
                            </div>
                        </div>
                        <div class="row g-2 mt-1">
                            <div class="col-6">
                                <label class="form-label small mb-0">Приоритет</label>
                                <input type="number" name="priority" class="form-control form-control-sm" value="0" />
                                <div class="form-text">Больше — раньше в расчёте заказа</div>
                            </div>
                            <div class="col-6 d-flex align-items-end">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" name="isActive" value="true" checked id="newCampActive" />
                                    <label class="form-check-label small" for="newCampActive">Активна</label>
                                </div>
                            </div>
                        </div>
                        <button type="submit" class="btn btn-success btn-sm mt-3">Добавить акцию</button>
                    </form>
                </div>
            </div>

            <div class="card shadow-sm">
                <div class="card-header bg-white fw-semibold">Список акций</div>
                <div class="card-body p-0">
                    @if (Model.Campaigns.Count == 0)
                    {
                        <p class="text-muted small p-3 mb-0">Пока нет кампаний</p>
                    }
                    else
                    {
                        <ul class="list-group list-group-flush">
                            @foreach (var c in Model.Campaigns)
                            {
                                <li class="list-group-item">
                                    <div class="d-flex justify-content-between align-items-start gap-2">
                                        <div>
                                            <strong>@c.Name</strong>
                                            @if (!string.IsNullOrEmpty(c.Description))
                                            {
                                                <div class="text-muted small">@c.Description</div>
                                            }
                                            <div class="small text-muted mt-1">
                                                @c.StartDate.ToString("dd.MM.yyyy HH:mm") — @c.EndDate.ToString("dd.MM.yyyy HH:mm")
                                                · приоритет @c.Priority
                                                · @(c.IsActive ? "активна" : "выкл.")
                                            </div>
                                        </div>
                                        <form asp-action="DeleteDiscountCampaign" method="post" class="flex-shrink-0" onsubmit="return confirm('Удалить акцию «@c.Name»?');">
                                            <input type="hidden" name="id" value="@c.Id" />
                                            <button type="submit" class="btn btn-outline-danger btn-sm" title="Удалить"><i class="fas fa-trash"></i></button>
                                        </form>
                                    </div>
                                    <details class="mt-2">
                                        <summary class="small text-primary" style="cursor:pointer;">Изменить</summary>
                                        <form asp-action="UpdateDiscountCampaign" method="post" class="border rounded p-2 mt-2 bg-light">
                                            <input type="hidden" name="id" value="@c.Id" />
                                            <div class="mb-2">
                                                <label class="form-label small mb-0">Название</label>
                                                <input type="text" name="name" class="form-control form-control-sm" value="@c.Name" required maxlength="150" />
                                            </div>
                                            <div class="mb-2">
                                                <label class="form-label small mb-0">Описание</label>
                                                <input type="text" name="description" class="form-control form-control-sm" value="@c.Description" maxlength="500" />
                                            </div>
                                            <div class="row g-2">
                                                <div class="col-md-6">
                                                    <label class="form-label small mb-0">Начало</label>
                                                    <input type="datetime-local" name="startDate" class="form-control form-control-sm" value="@c.StartDate.ToString("yyyy-MM-ddTHH:mm")" required />
                                                </div>
                                                <div class="col-md-6">
                                                    <label class="form-label small mb-0">Окончание</label>
                                                    <input type="datetime-local" name="endDate" class="form-control form-control-sm" value="@c.EndDate.ToString("yyyy-MM-ddTHH:mm")" required />
                                                </div>
                                            </div>
                                            <div class="row g-2 mt-1">
                                                <div class="col-6">
                                                    <label class="form-label small mb-0">Приоритет</label>
                                                    <input type="number" name="priority" class="form-control form-control-sm" value="@c.Priority" />
                                                </div>
                                                <div class="col-6 d-flex align-items-end">
                                                    <div class="form-check">
                                                        <input class="form-check-input" type="checkbox" name="isActive" value="true" id="camp_@(c.Id)_active" @(c.IsActive ? "checked" : null) />
                                                        <label class="form-check-label small" for="camp_@(c.Id)_active">Активна</label>
                                                    </div>
                                                </div>
                                            </div>
                                            <button type="submit" class="btn btn-primary btn-sm mt-2">Сохранить</button>
                                        </form>
                                    </details>
                                </li>
                            }
                        </ul>
                    }
                </div>
            </div>
        </div>

        <div class="col-lg-7">
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-white fw-semibold">Новое правило скидки</div>
                <div class="card-body">
                    <form asp-action="AddDiscountRule" method="post" class="rule-form-body">
                        <div class="row g-2">
                            <div class="col-md-4">
                                <label class="form-label small mb-0">Область</label>
                                <select name="scopeType" class="form-select form-select-sm" data-rule-scope required>
                                    <option value="Category">Категория</option>
                                    <option value="Client">Клиент</option>
                                </select>
                            </div>
                            <div class="col-md-4 rule-cat">
                                <label class="form-label small mb-0">Категория</label>
                                <select name="categoryId" class="form-select form-select-sm" asp-items="catList"></select>
                            </div>
                            <div class="col-md-4 rule-user" style="display:none;">
                                <label class="form-label small mb-0">Клиент (email в списке)</label>
                                <select name="userId" class="form-select form-select-sm" asp-items="userList"></select>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label small mb-0">Режим</label>
                                <select name="discountMode" class="form-select form-select-sm" required>
                                    <option value="Percent">Процент (%)</option>
                                    <option value="Amount">Фикс. сумма</option>
                                </select>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label small mb-0">Значение</label>
                                <input type="number" name="discountValue" class="form-control form-control-sm" step="0.01" min="0" required />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label small mb-0">Мин. сумма товаров (необяз.)</label>
                                <input type="number" name="minGoodsAmount" class="form-control form-control-sm" step="0.01" min="0" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label small mb-0">Акция (необяз.)</label>
                                <select name="campaignId" class="form-select form-select-sm">
                                    <option value="">—</option>
                                    @foreach (var camp in Model.Campaigns)
                                    {
                                        <option value="@camp.Id">@camp.Name</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-4 d-flex align-items-end">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" name="isActive" value="true" checked id="newRuleActive" />
                                    <label class="form-check-label small" for="newRuleActive">Активно</label>
                                </div>
                            </div>
                        </div>
                        <button type="submit" class="btn btn-success btn-sm mt-3">Добавить правило</button>
                    </form>
                </div>
            </div>

            <div class="card shadow-sm">
                <div class="card-header bg-white fw-semibold">Правила (@Model.Rules.Count)</div>
                <div class="card-body p-0">
                    @if (Model.Rules.Count == 0)
                    {
                        <p class="text-muted small p-3 mb-0">Правил пока нет</p>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-sm table-hover mb-0 align-middle">
                                <thead class="table-light">
                                    <tr>
                                        <th>ID</th>
                                        <th>Область</th>
                                        <th>Цель</th>
                                        <th>Режим</th>
                                        <th>Значение</th>
                                        <th>Акция</th>
                                        <th></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var r in Model.Rules)
                                    {
                                        var target = r.ScopeType == "Category"
                                        ? (r.CategoryName ?? ("#" + r.CategoryId))
                                        : ("user " + r.UserId);
                                        <tr>
                                            <td>@r.Id</td>
                                            <td>@(r.ScopeType == "Category" ? "Категория" : "Клиент")</td>
                                            <td class="small">@target</td>
                                            <td>@(r.DiscountMode == "Percent" ? "%" : "сумма")</td>
                                            <td>@r.DiscountValue.ToString("0.##")</td>
                                            <td class="small text-muted">@(r.CampaignName ?? "—")</td>
                                            <td class="text-end text-nowrap">
                                                <details>
                                                    <summary class="small text-primary d-inline" style="cursor:pointer;">Изм.</summary>
                                                    <div class="text-start border rounded p-2 mt-1 bg-light rule-form-body" style="min-width: 260px;">
                                                        <form asp-action="UpdateDiscountRule" method="post">
                                                            <input type="hidden" name="id" value="@r.Id" />
                                                            <div class="mb-2">
                                                                <label class="form-label small mb-0">Область</label>
                                                                <select name="scopeType" class="form-select form-select-sm" data-rule-scope required>
                                                                    @if (r.ScopeType == "Category")
                                                                    {
                                                                        <option value="Category" selected>Категория</option>
                                                                        <option value="Client">Клиент</option>
                                                                    }
                                                                    else
                                                                    {
                                                                        <option value="Category">Категория</option>
                                                                        <option value="Client" selected>Клиент</option>
                                                                    }
                                                                </select>
                                                            </div>
                                                            <div class="mb-2 rule-cat" style="display:@(r.ScopeType == "Category" ? "block" : "none")">
                                                                <label class="form-label small mb-0">Категория</label>
                                                                <select name="categoryId" class="form-select form-select-sm">
                                                                    @foreach (var cat in categoriesList)
                                                                    {
                                                                        if (r.CategoryId == cat.Id)
                                                                        {
                                                                            <option value="@cat.Id" selected>@cat.Name</option>
                                                                        }
                                                                        else
                                                                        {
                                                                            <option value="@cat.Id">@cat.Name</option>
                                                                        }
                                                                    }
                                                                </select>
                                                            </div>
                                                            <div class="mb-2 rule-user" style="display:@(r.ScopeType == "Client" ? "block" : "none")">
                                                                <label class="form-label small mb-0">Клиент</label>
                                                                <select name="userId" class="form-select form-select-sm">
                                                                    @foreach (var u in usersList)
                                                                    {
                                                                        if (r.UserId == u.Id)
                                                                        {
                                                                            <option value="@u.Id" selected>@u.Email</option>
                                                                        }
                                                                        else
                                                                        {
                                                                            <option value="@u.Id">@u.Email</option>
                                                                        }
                                                                    }
                                                                </select>
                                                            </div>
                                                            <div class="mb-2">
                                                                <label class="form-label small mb-0">Режим</label>
                                                                <select name="discountMode" class="form-select form-select-sm" required>
                                                                    @if (r.DiscountMode == "Percent")
                                                                    {
                                                                        <option value="Percent" selected>Процент</option>
                                                                        <option value="Amount">Фикс. сумма</option>
                                                                    }
                                                                    else
                                                                    {
                                                                        <option value="Percent">Процент</option>
                                                                        <option value="Amount" selected>Фикс. сумма</option>
                                                                    }
                                                                </select>
                                                            </div>
                                                            <div class="mb-2">
                                                                <label class="form-label small mb-0">Значение</label>
                                                                <input type="number" name="discountValue" class="form-control form-control-sm" step="0.01" value="@r.DiscountValue.ToString(System.Globalization.CultureInfo.InvariantCulture)" required />
                                                            </div>
                                                            <div class="mb-2">
                                                                <label class="form-label small mb-0">Мин. сумма</label>
                                                                <input type="number" name="minGoodsAmount" class="form-control form-control-sm" step="0.01" value="@(r.MinGoodsAmount?.ToString(System.Globalization.CultureInfo.InvariantCulture) ?? "")" />
                                                            </div>
                                                            <div class="mb-2">
                                                                <label class="form-label small mb-0">Акция</label>
                                                                <select name="campaignId" class="form-select form-select-sm">
                                                                    @if (!r.CampaignId.HasValue)
                                                                    {
                                                                        <option value="" selected>—</option>
                                                                    }
                                                                    else
                                                                    {
                                                                        <option value="">—</option>
                                                                    }
                                                                    @foreach (var camp in Model.Campaigns)
                                                                    {
                                                                        if (r.CampaignId == camp.Id)
                                                                        {
                                                                            <option value="@camp.Id" selected>@camp.Name</option>
                                                                        }
                                                                        else
                                                                        {
                                                                            <option value="@camp.Id">@camp.Name</option>
                                                                        }
                                                                    }
                                                                </select>
                                                            </div>
                                                            <div class="form-check mb-2">
                                                                @if (r.IsActive)
                                                                {
                                                                    <input class="form-check-input" type="checkbox" name="isActive" value="true" id="rule_@(r.Id)_a" checked />
                                                                }
                                                                else
                                                                {
                                                                    <input class="form-check-input" type="checkbox" name="isActive" value="true" id="rule_@(r.Id)_a" />
                                                                }
                                                                <label class="form-check-label small" for="rule_@(r.Id)_a">Активно</label>
                                                            </div>
                                                            <button type="submit" class="btn btn-primary btn-sm">Сохранить</button>
                                                        </form>
                                                    </div>
                                                </details>
                                                <form asp-action="DeleteDiscountRule" method="post" class="d-inline ms-1" onsubmit="return confirm('Удалить правило #@r.Id?');">
                                                    <input type="hidden" name="id" value="@r.Id" />
                                                    <button type="submit" class="btn btn-outline-danger btn-sm p-1" title="Удалить"><i class="fas fa-trash"></i></button>
                                                </form>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    document.querySelectorAll('[data-rule-scope]').forEach(function (sel) {
        function sync() {
            var body = sel.closest('.rule-form-body');
            if (!body) return;
            var cat = body.querySelector('.rule-cat');
            var usr = body.querySelector('.rule-user');
            if (!cat || !usr) return;
            var v = sel.value;
            cat.style.display = v === 'Category' ? '' : 'none';
            usr.style.display = v === 'Client' ? '' : 'none';
        }
        sel.addEventListener('change', sync);
        sync();
    });
</script>
