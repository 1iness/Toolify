@model HouseholdStore.Models.AdminDiscountsViewModel
@using Microsoft.AspNetCore.Mvc.Rendering
@using Toolify.ProductService.Models

@{
    ViewData["Title"] = "Скидки";
    Layout = "_AdminLayout";
    var catList = ViewBag.Categories as SelectList;
    var prodList = ViewBag.Products as SelectList;
    var categoriesList = ViewBag.CategoriesList as List<Category> ?? new List<Category>();
    var productsList = ViewBag.ProductsList as List<Product> ?? new List<Product>();

    var types = new[] {
        new { Key = "prod", Value = DiscountTypes.Product,  Label = DiscountTypes.Product  },
        new { Key = "cat",  Value = DiscountTypes.Category, Label = DiscountTypes.Category },
        new { Key = "qty",  Value = DiscountTypes.Quantity, Label = DiscountTypes.Quantity },
    };
    var kinds = new[] {
        new { Key = "pct", Value = DiscountValueKinds.Percent, Label = DiscountValueKinds.Percent },
        new { Key = "fix", Value = DiscountValueKinds.Fixed,   Label = DiscountValueKinds.Fixed   },
    };

    string FormatDiscount(Discount d)
    {
        var val = d.ValueKind == DiscountValueKinds.Percent
            ? $"−{d.Value:0.##}%"
            : $"−{d.Value:0.##}";

        switch (d.DiscountType)
        {
            case DiscountTypes.Product:
                return $"{val} на товар «{d.ProductName ?? ("#" + d.ProductId)}»";
            case DiscountTypes.Category:
                return $"{val} на категорию «{d.CategoryName ?? ("#" + d.CategoryId)}»";
            case DiscountTypes.Quantity:
                var target = d.ProductId.HasValue
                    ? $"товар «{d.ProductName ?? ("#" + d.ProductId)}»"
                    : $"категория «{d.CategoryName ?? ("#" + d.CategoryId)}»";
                return $"{val} от {d.MinQuantity} шт ({target})";
            default: return val;
        }
    }
}

<style>
    .disc-form-body .disc-field { display: none; }
    .disc-form-body .disc-field.visible { display: flex; }
    .disc-form-body .disc-target-group { display: none; }
    .disc-form-body .disc-target-group.visible { display: flex; gap: .5rem; }
</style>

<div class="container-fluid py-2 px-3">
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
        <a href="/Admin/Promotions" class="btn btn-outline-primary btn-sm">К акциям</a>
    </div>

    @if (TempData["Success"] != null) { <div class="alert alert-success">@TempData["Success"]</div> }
    @if (TempData["Error"]   != null) { <div class="alert alert-danger">@TempData["Error"]</div> }

    <div class="row g-4">
        <div class="col-lg-5">
            <div class="card shadow-sm">
                <div class="card-header bg-white fw-semibold">Новая скидка</div>
                <div class="card-body">
                    <form asp-action="AddDiscount" method="post" class="disc-form-body">
                        <div class="mb-2">
                            <label class="form-label small mb-0">Название</label>
                            <input type="text" name="Name" class="form-control form-control-sm" required maxlength="150" />
                        </div>
                        <div class="row g-2">
                            <div class="col-md-6">
                                <label class="form-label small mb-0">Тип скидки</label>
                                <select name="DiscountType" class="form-select form-select-sm" data-disc-type required>
                                    @foreach (var t in types)
                                    {
                                        <option value="@t.Value" data-key="@t.Key">@t.Label</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label small mb-0">Вид значения</label>
                                <select name="ValueKind" class="form-select form-select-sm" data-disc-kind required>
                                    @foreach (var k in kinds)
                                    {
                                        <option value="@k.Value" data-key="@k.Key">@k.Label</option>
                                    }
                                </select>
                            </div>
                        </div>

                        <div class="row g-2 mt-1">
                            <div class="col-md-6">
                                <label class="form-label small mb-0">Значение</label>
                                <input type="number" name="Value" class="form-control form-control-sm" min="0" step="0.01" required />
                            </div>
                            <div class="col-md-6 disc-field" data-show-type="qty">
                                <label class="form-label small mb-0">Мин. количество</label>
                                <input type="number" name="MinQuantity" class="form-control form-control-sm" min="1" step="1" />
                            </div>
                        </div>

                        <div class="row g-2 mt-1 disc-target-group" data-disc-target>
                            <div class="col-md-6 disc-field" data-show-type="prod,qty">
                                <label class="form-label small mb-0">Товар</label>
                                <select name="ProductId" class="form-select form-select-sm">
                                    <option value="">—</option>
                                    @foreach (var pr in productsList)
                                    {
                                        <option value="@pr.Id">@pr.Name</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-6 disc-field" data-show-type="cat,qty">
                                <label class="form-label small mb-0">Категория</label>
                                <select name="CategoryId" class="form-select form-select-sm">
                                    <option value="">—</option>
                                    @foreach (var c in categoriesList)
                                    {
                                        <option value="@c.Id">@c.Name</option>
                                    }
                                </select>
                            </div>
                        </div>

                        <div class="form-check mt-3">
                            <input class="form-check-input" type="checkbox" name="IsActive" value="true" checked id="newDiscActive" />
                            <input type="hidden" name="IsActive" value="false" />
                            <label class="form-check-label small" for="newDiscActive">Активна</label>
                        </div>

                        <div class="disc-warning small text-muted mt-2"></div>
                        <button type="submit" class="btn btn-success btn-sm mt-3">Добавить скидку</button>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-lg-7">
            <div class="card shadow-sm">
                <div class="card-header bg-white fw-semibold">Список скидок (@Model.Discounts.Count)</div>
                <div class="card-body p-0">
                    @if (Model.Discounts.Count == 0)
                    {
                        <p class="text-muted small p-3 mb-0">Пока нет скидок</p>
                    }
                    else
                    {
                        <ul class="list-group list-group-flush">
                            @foreach (var d in Model.Discounts)
                            {
                                <li class="list-group-item">
                                    <div class="d-flex justify-content-between align-items-start gap-2">
                                        <div>
                                            <strong>@d.Name</strong>
                                            <span class="badge bg-primary-subtle text-primary-emphasis ms-1">@d.DiscountType</span>
                                            @if (!d.IsActive) { <span class="badge bg-secondary">выкл.</span> }
                                            <div class="small text-muted mt-1">@FormatDiscount(d)</div>
                                        </div>
                                        <form asp-action="DeleteDiscount" method="post" class="flex-shrink-0"
                                              onsubmit="return confirm('Удалить скидку «@d.Name»?');">
                                            <input type="hidden" name="id" value="@d.Id" />
                                            <button type="submit" class="btn btn-outline-danger btn-sm" title="Удалить"><i class="fas fa-trash"></i></button>
                                        </form>
                                    </div>

                                    <details class="mt-2">
                                        <summary class="small text-primary" style="cursor:pointer;">Изменить</summary>
                                        <form asp-action="UpdateDiscount" method="post" class="border rounded p-2 mt-2 bg-light disc-form-body">
                                            <input type="hidden" name="Id" value="@d.Id" />
                                            <div class="mb-2">
                                                <label class="form-label small mb-0">Название</label>
                                                <input type="text" name="Name" class="form-control form-control-sm" value="@d.Name" required maxlength="150" />
                                            </div>
                                            <div class="row g-2">
                                                <div class="col-md-6">
                                                    <label class="form-label small mb-0">Тип</label>
                                                    <select name="DiscountType" class="form-select form-select-sm" data-disc-type required>
                                                        @foreach (var t in types)
                                                        {
                                                            if (t.Value == d.DiscountType)
                                                            { <option value="@t.Value" data-key="@t.Key" selected>@t.Label</option> }
                                                            else
                                                            { <option value="@t.Value" data-key="@t.Key">@t.Label</option> }
                                                        }
                                                    </select>
                                                </div>
                                                <div class="col-md-6">
                                                    <label class="form-label small mb-0">Вид</label>
                                                    <select name="ValueKind" class="form-select form-select-sm" data-disc-kind required>
                                                        @foreach (var k in kinds)
                                                        {
                                                            if (k.Value == d.ValueKind)
                                                            { <option value="@k.Value" data-key="@k.Key" selected>@k.Label</option> }
                                                            else
                                                            { <option value="@k.Value" data-key="@k.Key">@k.Label</option> }
                                                        }
                                                    </select>
                                                </div>
                                            </div>
                                            <div class="row g-2 mt-1">
                                                <div class="col-md-6">
                                                    <label class="form-label small mb-0">Значение</label>
                                                    <input type="number" name="Value" class="form-control form-control-sm" min="0" step="0.01" value="@d.Value.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)" required />
                                                </div>
                                                <div class="col-md-6 disc-field" data-show-type="qty">
                                                    <label class="form-label small mb-0">Мин. количество</label>
                                                    <input type="number" name="MinQuantity" class="form-control form-control-sm" min="1" step="1" value="@(d.MinQuantity?.ToString() ?? "")" />
                                                </div>
                                            </div>
                                            <div class="row g-2 mt-1 disc-target-group" data-disc-target>
                                                <div class="col-md-6 disc-field" data-show-type="prod,qty">
                                                    <label class="form-label small mb-0">Товар</label>
                                                    <select name="ProductId" class="form-select form-select-sm">
                                                        <option value="">—</option>
                                                        @foreach (var pr in productsList)
                                                        {
                                                            if (d.ProductId == pr.Id)
                                                            { <option value="@pr.Id" selected>@pr.Name</option> }
                                                            else
                                                            { <option value="@pr.Id">@pr.Name</option> }
                                                        }
                                                    </select>
                                                </div>
                                                <div class="col-md-6 disc-field" data-show-type="cat,qty">
                                                    <label class="form-label small mb-0">Категория</label>
                                                    <select name="CategoryId" class="form-select form-select-sm">
                                                        <option value="">—</option>
                                                        @foreach (var c in categoriesList)
                                                        {
                                                            if (d.CategoryId == c.Id)
                                                            { <option value="@c.Id" selected>@c.Name</option> }
                                                            else
                                                            { <option value="@c.Id">@c.Name</option> }
                                                        }
                                                    </select>
                                                </div>
                                            </div>
                                            <div class="form-check mt-3">
                                                <input class="form-check-input" type="checkbox" name="IsActive" value="true" id="disc_@(d.Id)_a" @(d.IsActive ? "checked" : null) />
                                                <input type="hidden" name="IsActive" value="false" />
                                                <label class="form-check-label small" for="disc_@(d.Id)_a">Активна</label>
                                            </div>
                                            <div class="disc-warning small text-muted mt-2"></div>
                                            <button type="submit" class="btn btn-primary btn-sm mt-2">Сохранить</button>
                                        </form>
                                    </details>
                                </li>
                            }
                        </ul>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    (function () {
        function setupForm(body) {
            var typeSel = body.querySelector('[data-disc-type]');
            var targetGroup = body.querySelector('[data-disc-target]');
            var warn = body.querySelector('.disc-warning');

            function currentKey(sel) {
                if (!sel) return '';
                var opt = sel.options[sel.selectedIndex];
                return opt ? (opt.getAttribute('data-key') || '') : '';
            }

            function apply() {
                var tKey = currentKey(typeSel);

                body.querySelectorAll('.disc-field').forEach(function (el) {
                    var want = (el.getAttribute('data-show-type') || '').split(',').filter(Boolean);
                    if (want.length === 0 || want.indexOf(tKey) !== -1) el.classList.add('visible');
                    else                                                el.classList.remove('visible');
                });

                if (targetGroup) {
                    if (tKey === 'prod' || tKey === 'cat' || tKey === 'qty')
                        targetGroup.classList.add('visible');
                    else
                        targetGroup.classList.remove('visible');
                }

                if (warn) {
                    warn.textContent = (tKey === 'qty')
                        ? 'Для скидки «Количество» выберите товар ИЛИ категорию — не оба поля.'
                        : '';
                }
            }

            if (typeSel) typeSel.addEventListener('change', apply);
            apply();
        }

        document.querySelectorAll('.disc-form-body').forEach(setupForm);
    })();
</script>
