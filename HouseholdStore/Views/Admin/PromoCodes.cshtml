@model IEnumerable<Toolify.ProductService.Models.PromoCode>

@{
    ViewData["Title"] = "Управление промокодами";
    Layout = null;
}

<link rel="stylesheet" href="~/css/promocodes.css" />
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">

<div class="container-fluid py-4 promo-container">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="h3 mb-0 text-dark fw-bold">Управление промокодами</h2>
        <a href="/Admin/Index" class="btn btn-outline-secondary btn-sm"><i class="fas fa-arrow-left"></i> Назад в панель</a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    <div class="row">

        <div class="col-lg-4 mb-4">
            <div class="card promo-card">
                <div class="promo-card-header">
                    <h6 class="promo-card-title">Создать новый промокод</h6>
                </div>
                <div class="card-body">
                    <form asp-action="CreatePromoCode" method="post">
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Код</label>
                            <input type="text" name="Code" class="form-control input-promo-code" placeholder="Например: NEWYEAR" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Скидка (%)</label>
                            <input type="number" name="DiscountPercent" class="form-control" min="1" max="100" placeholder="От 1 до 100" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Начало действия</label>
                            <input type="datetime-local" name="StartDate" id="startDate" class="form-control" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Конец действия</label>
                            <input type="datetime-local" name="EndDate" id="endDate" class="form-control" required />
                        </div>
                        <div class="mb-4">
                            <label class="form-label fw-semibold">Лимит использований</label>
                            <input type="number" name="maxUses" class="form-control" min="1" max="999999999" step="1" placeholder="Необязательно" />
                            <div class="form-text">Пусто — без лимита по числу заказов (действует только срок). Число — максимум успешных заказов с этим кодом за указанный период.</div>
                        </div>
                        <div class="mb-4">
                            <label class="form-label fw-semibold">Мин. сумма товаров</label>
                            <input type="number" name="minGoodsAmount" class="form-control" min="0" step="0.01" placeholder="Необязательно" />
                            <div class="form-text">Если указать, промокод применится только когда сумма товаров (после скидок по товарам/категориям/клиенту, но до промокода) не меньше этого значения.</div>
                        </div>
                        <button type="submit" class="btn btn-primary w-100 fw-bold">Добавить промокод</button>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-lg-8">
            <div class="card promo-card">
                <div class="promo-card-header">
                    <h6 class="promo-card-title">Список активных и прошедших акций</h6>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover promo-table mb-0">
                            <thead class="bg-light">
                                <tr>
                                    <th>Код</th>
                                    <th>Скидка</th>
                                    <th>Срок действия</th>
                                    <th>Использования</th>
                                    <th>Статус</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model != null && Model.Any())
                                {
                                    foreach (var promo in Model)
                                    {
                                        var isActive = promo.IsValid;
                                        <tr>
                                            <td class="fw-bold text-dark">@promo.Code</td>
                                            <td><span class="badge bg-success" style="font-size: 0.9em;">-@promo.DiscountPercent%</span></td>
                                            <td class="text-muted" style="font-size: 0.85rem;">
                                                @promo.StartDate.ToString("dd.MM.yyyy HH:mm") <br />
                                                <i class="fas fa-long-arrow-alt-down"></i> <br />
                                                @promo.EndDate.ToString("dd.MM.yyyy HH:mm")
                                            </td>
                                            <td class="text-muted" style="font-size: 0.85rem;">
                                                @if (promo.MaxUses.HasValue)
                                                {
                                                    <span>@promo.UsedCount / @promo.MaxUses.Value</span>
                                                }
                                                else
                                                {
                                                    <span>—</span>
                                                }
                                            </td>
                                            <td>
                                                @if (isActive)
                                                {
                                                    <span class="promo-badge promo-badge-active"><i class="fas fa-check-circle"></i> Активен</span>
                                                }
                                                else
                                                {
                                                    <span class="promo-badge promo-badge-expired"><i class="fas fa-times-circle"></i> Недоступен</span>
                                                }
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="5" class="text-center text-muted py-5">
                                            <i class="fas fa-ticket-alt fa-3x mb-3 text-light"></i><br />
                                            Промокоды пока не созданы
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function() {
        const now = new Date();
        const offset = now.getTimezoneOffset() * 60000;

        const localISOTime = (new Date(now - offset)).toISOString().slice(0, 16);
        document.getElementById('startDate').value = localISOTime;

        const nextMonth = new Date(now.setMonth(now.getMonth() + 1));
        const nextMonthISO = (new Date(nextMonth - offset)).toISOString().slice(0, 16);
        document.getElementById('endDate').value = nextMonthISO;
    });
</script>