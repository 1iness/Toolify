@model Toolify.ProductService.Models.Product

@{
    ViewData["Title"] = "Добавить товар";
    Layout = null; 
}

<link rel="stylesheet" href="~/css/site.css" />

<div style="padding: 20px;">
    <h1>Добавить товар</h1>

    <div asp-validation-summary="All" style="color:red"></div>

    <form method="post" enctype="multipart/form-data" asp-action="Create">

        <div style="border: 1px solid #ddd; padding: 10px; margin-bottom: 10px;">
            <p><strong>Категория:</strong></p>
            <select name="CategoryId" asp-items="ViewBag.Categories" style="width: 200px; padding: 5px;">
                <option value="">-- Выберите из списка --</option>
            </select>

            <p style="margin: 5px 0;"><em>--- ИЛИ создайте новую ---</em></p>

            <input type="text" name="NewCategoryName" placeholder="Название новой категории" style="width: 200px;" />
        </div>

        <div id="features-section" style="display:none; margin-top: 20px; border: 1px solid #eee; padding: 15px; border-radius: 8px; background-color: #f9f9f9;">
            <h3 style="font-size: 16px; margin-bottom: 15px;">Характеристики для выбранной категории</h3>
            <div id="features-container">
                @if (Model.Configurations != null && Model.Configurations.Any())
                {
                    for (int i = 0; i < Model.Configurations.Count; i++)
                    {
                        var config = Model.Configurations[i];
                        <div class="feature-row" style="display: flex; align-items: center; margin-bottom: 10px;">
                            <div style="flex-grow: 1;">
                                <label style="display:block; font-weight:500;">@config.FeatureName:</label>
                                <input type="hidden" name="Configurations[@i].FeatureId" value="@config.FeatureId" />
                                <input type="hidden" name="Configurations[@i].FeatureName" value="@config.FeatureName" />
                                <input type="text" name="Configurations[@i].FeatureValue" value="@config.FeatureValue"
                                       style="width: 100%; padding: 8px; border: 1px solid #ccc; border-radius: 4px;" />
                            </div>
                            <button type="button" onclick="removeFeature(this)"
                                    style="margin-left: 10px; margin-top: 20px; background: #ff4d4d; color: white; border: none; border-radius: 4px; padding: 5px 10px; cursor: pointer;">
                                ✕
                            </button>
                        </div>
                    }
                }
            </div>
        </div>

        <div id="custom-features-container"></div>
        <button type="button" onclick="addCustomFeature()" style="margin-top: 10px; background: #6c757d; color: white; border: none; padding: 5px 10px; border-radius: 4px; cursor: pointer;">
            + Добавить свое поле
        </button>

        <p>Название:</p>
        <input type="text" name="Name" value="@Model?.Name" required />

        <p>Описание (краткое):</p>
        <input type="text" name="ShortDescription" value="@Model?.ShortDescription" />

        <p>Описание (полное):</p>
        <textarea name="FullDescription" rows="4" cols="50">@Model?.FullDescription</textarea>

        <p>Цена:</p>
        <input type="number" name="Price" value="@Model?.Price" step="0.01" required />

        <p>Количество на складе:</p>
        <input type="number" name="StockQuantity" value="@(Model?.StockQuantity ?? 0)" min="0" required />

        <p>Изображение:</p>
        <input type="file" name="image" />

        <p>Скидка (%):</p>
        <input type="number" name="Discount" value="@(Model?.Discount ?? 0)" min="0" max="100" />

        <br /><br />
        <button type="submit">Добавить</button>
        <a href="/Admin/Index">Отмена</a>
    </form>
</div>

<script>
    document.querySelector('select[name="CategoryId"]').addEventListener('change', async function () {
        const categoryId = this.value;
        const container = document.getElementById('features-container');
        const section = document.getElementById('features-section');
        container.innerHTML = ''; 

        if (!categoryId) {
            section.style.display = 'none';
            return;
        }

        try {
            const response = await fetch(`/Admin/GetFeatures?categoryId=${categoryId}`);
            const data = await response.json();

            if (data && data.length > 0) {
                section.style.display = 'block';
                data.forEach((feature, index) => {
                    const div = document.createElement('div');
                    div.className = 'feature-row'; 
                    div.style = "display: flex; align-items: center; gap: 10px; margin-bottom: 10px; padding: 10px; border: 1px solid #eee; border-radius: 4px;";

                    div.innerHTML = `
                        <div style="flex-grow: 1; display: flex; gap: 10px;">
                            <div style="flex-grow: 1;">
                                <label style="display:block; font-size: 12px; color: gray;">Характеристика:</label>
                                <input type="text" name="Configurations[${index}].FeatureName" value="${feature.name}" readonly
                                       style="width: 100%; background: #f0f0f0; border: 1px solid #ccc; padding: 5px;" />
                            </div>
                            <div style="flex-grow: 1;">
                                <label style="display:block; font-size: 12px; color: gray;">Значение:</label>
                                <input type="text" name="Configurations[${index}].FeatureValue" placeholder="Введите значение..." required
                                       style="width: 100%; border: 1px solid #ccc; padding: 5px;" />
                            </div>
                            <input type="hidden" name="Configurations[${index}].FeatureId" value="${feature.id}" />
                        </div>
                        <button type="button" onclick="removeFeature(this)"
                                style="margin-top: 18px; background: #ff4d4d; color: white; border: none; border-radius: 4px; padding: 5px 10px; cursor: pointer;">
                            ✕
                        </button>
                    `;
                    container.appendChild(div);
                });
            } else {
                section.style.display = 'none';
            }
        } catch (error) {
            console.error('Ошибка:', error);
        }
    });

           function addCustomFeature() {
        const container = document.getElementById('features-container');
        const section = document.getElementById('features-section');
        section.style.display = 'block';

        const div = document.createElement('div');
        div.className = 'feature-row';
        div.style = "display: flex; align-items: center; gap: 10px; margin-bottom: 10px; padding: 10px; border: 1px dashed #ccc; border-radius: 4px;";

        div.innerHTML = `
            <div style="flex-grow: 1; display: flex; gap: 10px;">
                <div style="flex-grow: 1;">
                    <input type="text" placeholder="Название (напр. Вес)" name="Configurations[X].FeatureName" required
                           style="width: 100%; border: 1px solid #ccc; padding: 5px;" />
                </div>
                <div style="flex-grow: 1;">
                    <input type="text" placeholder="Значение" name="Configurations[X].FeatureValue" required
                           style="width: 100%; border: 1px solid #ccc; padding: 5px;" />
                </div>
                <input type="hidden" name="Configurations[X].FeatureId" value="0" />
            </div>
            <button type="button" onclick="removeFeature(this)"
                    style="background: #ff4d4d; color: white; border: none; border-radius: 4px; padding: 5px 10px; cursor: pointer;">
                ✕
            </button>
        `;
        container.appendChild(div);
        reindexFeatures(); 
    }

    function removeFeature(btn) {
        const row = btn.closest('.feature-row');
        row.remove();
        reindexFeatures(); 

        const container = document.getElementById('features-container');
        if (container.children.length === 0) {
            document.getElementById('features-section').style.display = 'none';
        }
    }

    function reindexFeatures() {
        const container = document.getElementById('features-container');
        const rows = container.getElementsByClassName('feature-row');

        for (let i = 0; i < rows.length; i++) {
            const inputs = rows[i].querySelectorAll('input');
            inputs.forEach(input => {
                const name = input.getAttribute('name');
                if (name) {
                    input.setAttribute('name', name.replace(/\[\d+\]|\[X\]/, `[${i}]`));
                }
            });
        }
    }

</script>