@model Toolify.ProductService.Models.Product

@{
    ViewData["Title"] = "Добавить товар";
    Layout = null;
}

<link rel="stylesheet" href="~/css/create-product.css" />

<div class="admin-form-wrapper">
    <h1>Добавить товар</h1>

    <div asp-validation-summary="All" style="color:red; margin-bottom: 15px;"></div>

    <form method="post" enctype="multipart/form-data" asp-action="Create">

        <div class="category-box">
            <div class="form-group">
                <p>Категория:</p>
                <select name="CategoryId" asp-items="ViewBag.Categories" class="form-select" style="max-width: 300px;">
                    <option value="">-- Выберите из списка --</option>
                </select>
            </div>

            <p style="margin: 10px 0; color: #888; font-size: 12px;"><em>--- ИЛИ создайте новую ---</em></p>

            <div class="form-group">
                <input type="text" name="NewCategoryName" placeholder="Название новой категории" class="form-input" style="max-width: 300px;" />
            </div>
        </div>

        <div id="features-section" class="features-section" style="display:none;">
            <h3 style="font-size: 16px; margin-top: 0; margin-bottom: 15px;">Характеристики для выбранной категории</h3>
            <div id="features-container">
                @if (Model?.Configurations != null && Model.Configurations.Any())
                {
                    for (int i = 0; i < Model.Configurations.Count; i++)
                    {
                        var config = Model.Configurations[i];
                        <div class="feature-row">
                            <div style="flex-grow: 1;">
                                <label style="display:block; font-weight:500; margin-bottom: 5px;">@config.FeatureName:</label>
                                <input type="hidden" name="Configurations[@i].FeatureId" value="@config.FeatureId" />
                                <input type="hidden" name="Configurations[@i].FeatureName" value="@config.FeatureName" />
                                <input type="text" name="Configurations[@i].FeatureValue" value="@config.FeatureValue" class="form-input" />
                            </div>
                            <button type="button" onclick="removeFeature(this)" class="btn btn-danger" style="margin-top: 22px;">✕</button>
                        </div>
                    }
                }
            </div>
        </div>

        <div id="custom-features-container"></div>

        <div class="form-group" style="margin-top: 10px; margin-bottom: 25px;">
            <button type="button" onclick="addCustomFeature()" class="btn btn-secondary">
                + Добавить свое поле
            </button>
        </div>

        <div class="form-group">
            <p>Название:</p>
            <input type="text" name="Name" value="@Model?.Name" class="form-input" required />
        </div>

        <div class="form-group">
            <p>Описание (краткое):</p>
            <input type="text" name="ShortDescription" value="@Model?.ShortDescription" class="form-input" />
        </div>

        <div class="form-group">
            <p>Описание (полное):</p>
            <textarea name="FullDescription" rows="4" class="form-textarea">@Model?.FullDescription</textarea>
        </div>

        <div class="form-group">
            <p>Цена:</p>
            <input type="number" name="Price" value="@Model?.Price" step="0.01" class="form-input" required />
        </div>

        <div class="form-group">
            <p>Количество на складе:</p>
            <input type="number" name="StockQuantity" value="@(Model?.StockQuantity ?? 0)" min="0" class="form-input" required />
        </div>

        <div class="form-group">
            <p>Изображение:</p>
            <input type="file" name="image" class="form-input" style="padding: 7px 15px;" />
        </div>

        <div style="margin-top: 30px;">
            <button type="submit" class="btn btn-primary">Добавить</button>
            <a href="/Admin/Index" class="btn btn-cancel">Отмена</a>
        </div>
    </form>
</div>

<script>
    document.querySelector('select[name="CategoryId"]').addEventListener('change', async function () {
        const categoryId = this.value;
        const container = document.getElementById('features-container');
        const section = document.getElementById('features-section');
        container.innerHTML = '';

        if (!categoryId) {
            section.style.display = 'none';
            return;
        }

        try {
            const response = await fetch(`/Admin/GetFeatures?categoryId=${categoryId}`);
            const data = await response.json();

            if (data && data.length > 0) {
                section.style.display = 'block';
                data.forEach((feature, index) => {
                    const div = document.createElement('div');
                    div.className = 'feature-row';
                    div.innerHTML = `
                        <div style="flex-grow: 1; display: flex; gap: 15px;">
                            <div style="flex-grow: 1;">
                                <label style="display:block; font-size: 12px; color: gray; margin-bottom: 5px;">Характеристика:</label>
                                <input type="text" name="Configurations[${index}].FeatureName" value="${feature.name}" readonly class="form-input" style="background: #f0f0f0;" />
                            </div>
                            <div style="flex-grow: 1;">
                                <label style="display:block; font-size: 12px; color: gray; margin-bottom: 5px;">Значение:</label>
                                <input type="text" name="Configurations[${index}].FeatureValue" placeholder="Введите значение..." required class="form-input" />
                            </div>
                            <input type="hidden" name="Configurations[${index}].FeatureId" value="${feature.id}" />
                        </div>
                        <button type="button" onclick="removeFeature(this)" class="btn btn-danger" style="margin-top: 22px;">✕</button>
                    `;
                    container.appendChild(div);
                });
            } else {
                section.style.display = 'none';
            }
        } catch (error) {
            console.error('Ошибка:', error);
        }
    });

    function addCustomFeature() {
        const container = document.getElementById('features-container');
        const section = document.getElementById('features-section');
        section.style.display = 'block';

        const div = document.createElement('div');
        div.className = 'feature-row';
        div.innerHTML = `
            <div style="flex-grow: 1; display: flex; gap: 15px;">
                <div style="flex-grow: 1;">
                    <input type="text" placeholder="Название (напр. Вес)" name="Configurations[X].FeatureName" required class="form-input" />
                </div>
                <div style="flex-grow: 1;">
                    <input type="text" placeholder="Значение" name="Configurations[X].FeatureValue" required class="form-input" />
                </div>
                <input type="hidden" name="Configurations[X].FeatureId" value="0" />
            </div>
            <button type="button" onclick="removeFeature(this)" class="btn btn-danger">✕</button>
        `;
        container.appendChild(div);
        reindexFeatures();
    }

    function removeFeature(btn) {
        const row = btn.closest('.feature-row');
        row.remove();
        reindexFeatures();

        const container = document.getElementById('features-container');
        if (container.children.length === 0) {
            document.getElementById('features-section').style.display = 'none';
        }
    }

    function reindexFeatures() {
        const container = document.getElementById('features-container');
        const rows = container.getElementsByClassName('feature-row');

        for (let i = 0; i < rows.length; i++) {
            const inputs = rows[i].querySelectorAll('input');
            inputs.forEach(input => {
                const name = input.getAttribute('name');
                if (name) {
                    input.setAttribute('name', name.replace(/\[\d+\]|\[X\]/, `[${i}]`));
                }
            });
        }
    }
</script>