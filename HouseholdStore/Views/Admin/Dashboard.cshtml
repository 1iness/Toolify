@model HouseholdStore.Models.DashboardViewModel
@{
    ViewData["Title"] = "Дашборд Аналитики";
    Layout = null;
}

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
<link rel="stylesheet" href="~/css/dashboard.css" />

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="fas fa-chart-line me-2"></i>Аналитика Toolify</h2>
        <div>
            <a href="/Admin/List" class="btn btn-outline-primary"><i class="fas fa-box"></i> Товары</a>
            <a href="/Admin/Orders" class="btn btn-outline-primary"><i class="fas fa-shopping-cart"></i> Заказы</a>
            <a href="/Admin/Reports" class="btn btn-outline-primary"><i class="fas fa-file-lines"></i> Отчёты</a>
            <a href="/Chat/Admin" class="btn btn-outline-primary"><i class="fas fa-comments"></i> Чат</a>
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-md-6">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-white d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">Заказы по статусам</h5>
                    <a href="/Admin/ExportOrdersByStatus" class="btn btn-sm btn-success"><i class="fas fa-file-excel"></i> CSV</a>
                </div>
                <div class="card-body">
                    <canvas id="statusChart" style="max-height: 300px;"></canvas>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-white d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">Товары по категориям</h5>
                    <a href="/Admin/ExportProductsByCategory" class="btn btn-sm btn-success"><i class="fas fa-file-excel"></i> CSV</a>
                </div>
                <div class="card-body">
                    <canvas id="categoryChart" style="max-height: 300px;"></canvas>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm mb-4">
        <div class="card-header bg-white d-flex justify-content-between align-items-center">
            <h5 class="mb-0">История взаимоотношений с клиентами</h5>
            <a href="/Admin/ExportClientHistory" class="btn btn-sm btn-success"><i class="fas fa-file-excel"></i> Экспорт истории</a>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Клиент</th>
                            <th>Email</th>
                            <th>Заказов</th>
                            <th>Общая сумма</th>
                            <th>Последний заказ</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model?.ClientHistory != null && Model.ClientHistory.Any())
                        {
                            foreach (var client in Model.ClientHistory)
                            {
                                <tr>
                                    <td>@client.ClientName</td>
                                    <td>@client.ClientEmail</td>
                                    <td><span class="badge bg-primary rounded-pill">@client.TotalOrders</span></td>
                                    <td class="fw-bold">@client.TotalSpent.ToString("N2") <span class="nbrb-icon">&#xE901;</span></td>
                                    <td>@client.LastOrderDate.ToShortDateString()</td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr><td colspan="5" class="text-center text-muted py-4">Данные отсутствуют</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        var statusLabels = @Html.Raw(Json.Serialize(Model?.OrdersByStatus?.Select(x => x.Status) ?? new string[] { }));
        var statusData = @Html.Raw(Json.Serialize(Model?.OrdersByStatus?.Select(x => x.OrderCount) ?? new int[] { }));

        new Chart(document.getElementById('statusChart'), {
            type: 'doughnut',
            data: {
                labels: statusLabels,
                datasets: [{
                    data: statusData,
                    backgroundColor: ['#0dcaf0', '#ffc107', '#198754', '#dc3545', '#6c757d', '#0d6efd']
                }]
            },
            options: { responsive: true, maintainAspectRatio: false }
        });

        var catLabels = @Html.Raw(Json.Serialize(Model?.ProductsByCategory?.Select(x => x.CategoryName) ?? new string[] { }));
        var catData = @Html.Raw(Json.Serialize(Model?.ProductsByCategory?.Select(x => x.ProductCount) ?? new int[] { }));

        new Chart(document.getElementById('categoryChart'), {
            type: 'bar',
            data: {
                labels: catLabels,
                datasets: [{
                    label: 'Количество товаров',
                    data: catData,
                    backgroundColor: '#0d6efd'
                }]
            },
            options: { responsive: true, maintainAspectRatio: false }
        });
    });
</script>