@model HouseholdStore.Models.DashboardViewModel
@{
    ViewData["Title"] = "Общая статистика";
    Layout = "_AdminLayout";
}

<link rel="stylesheet" href="~/css/dashboard.css" />

<div class="container-fluid py-2 admin-dashboard-inner">
    <div class="row mb-4">
        <div class="col-md-6">
            <div class="card shadow-sm h-100 admin-panel-card border-0">
                <div class="card-header bg-white d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">Заказы по статусам</h5>
                    <a href="/Admin/ExportOrdersByStatus" class="btn btn-sm btn-success" data-admin-no-spa="1"><i class="fas fa-file-excel"></i> CSV</a>
                </div>
                <div class="card-body admin-chart-slot">
                    <canvas id="statusChart"></canvas>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card shadow-sm h-100 admin-panel-card border-0">
                <div class="card-header bg-white d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">Товары по категориям</h5>
                    <a href="/Admin/ExportProductsByCategory" class="btn btn-sm btn-success" data-admin-no-spa="1"><i class="fas fa-file-excel"></i> CSV</a>
                </div>
                <div class="card-body admin-chart-slot">
                    <canvas id="categoryChart"></canvas>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm mb-4 admin-panel-card border-0">
        <div class="card-header bg-white d-flex justify-content-between align-items-center">
            <h5 class="mb-0">История взаимоотношений с клиентами</h5>
            <a href="/Admin/ExportClientHistory" class="btn btn-sm btn-success" data-admin-no-spa="1"><i class="fas fa-file-excel"></i> Экспорт истории</a>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0 admin-dashboard-history-table">
                    <thead class="table-light">
                        <tr>
                            <th>Клиент</th>
                            <th>Email</th>
                            <th>Заказов</th>
                            <th>Общая сумма</th>
                            <th>Последний заказ</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model?.ClientHistory != null && Model.ClientHistory.Any())
                        {
                            foreach (var client in Model.ClientHistory)
                            {
                                <tr>
                                    <td>@client.ClientName</td>
                                    <td>@client.ClientEmail</td>
                                    <td><span class="badge rounded-pill" style="background:#218838;">@client.TotalOrders</span></td>
                                    <td class="fw-bold">@client.TotalSpent.ToString("N2") <span class="nbrb-icon">&#xE901;</span></td>
                                    <td>@client.LastOrderDate.ToShortDateString()</td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr><td colspan="5" class="text-center text-muted py-4">Данные отсутствуют</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<script>
    function initAdminDashboardCharts() {
        var statusCanvas = document.getElementById('statusChart');
        var categoryCanvas = document.getElementById('categoryChart');
        if (!statusCanvas || !categoryCanvas || typeof Chart === 'undefined') return;

        var prevStatus = Chart.getChart(statusCanvas);
        if (prevStatus) prevStatus.destroy();
        var prevCat = Chart.getChart(categoryCanvas);
        if (prevCat) prevCat.destroy();

        var statusLabels = @Html.Raw(Json.Serialize(Model?.OrdersByStatus?.Select(x => x.Status) ?? new string[] { }));
        var statusData = @Html.Raw(Json.Serialize(Model?.OrdersByStatus?.Select(x => x.OrderCount) ?? new int[] { }));

        function draw() {
            new Chart(statusCanvas, {
            type: 'doughnut',
            data: {
                labels: statusLabels,
                datasets: [{
                    data: statusData,
                    backgroundColor: ['#218838', '#5cb85c', '#17a2b8', '#ffc107', '#dc3546', '#6c757d']
                }]
            },
            options: { responsive: true, maintainAspectRatio: false }
        });

            var catLabels = @Html.Raw(Json.Serialize(Model?.ProductsByCategory?.Select(x => x.CategoryName) ?? new string[] { }));
            var catData = @Html.Raw(Json.Serialize(Model?.ProductsByCategory?.Select(x => x.ProductCount) ?? new int[] { }));

            new Chart(categoryCanvas, {
            type: 'bar',
            data: {
                labels: catLabels,
                datasets: [{
                    label: 'Количество товаров',
                    data: catData,
                    backgroundColor: '#218838'
                }]
            },
            options: { responsive: true, maintainAspectRatio: false }
        });
        }

        requestAnimationFrame(function () {
            requestAnimationFrame(draw);
        });
    }

    document.addEventListener('DOMContentLoaded', initAdminDashboardCharts);
    document.addEventListener('admin-panel-loaded', initAdminDashboardCharts);
</script>
