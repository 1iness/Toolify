@model IEnumerable<Toolify.ProductService.Models.Product>

@{
    ViewData["Title"] = "Список товаров";
    Layout = null; 
}

<link rel="stylesheet" href="~/css/site.css" />
<link rel="stylesheet" href="~/css/list.css" />

<div class="admin-list-container">
    <h1>Список товаров</h1>
    <p>
        <a href="/Admin/Create" class="btn-create">
            <i class="bi bi-plus-lg"></i> Добавить новый товар
        </a>
    </p>

    <table class="admin-table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Фото</th>
                <th>Название</th>
                <th>Цена</th>
                <th style="text-align: center;">Скидка</th>
                <th>Кол-во</th>
                <th>Действия</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Id</td>
                    <td>
                        <img src="https://localhost:7188/api/Product/@(item.Id)/image"
                             class="product-img-preview"
                             onerror="this.onerror=null; this.src='/image/no-image.png';" />
                    </td>
                    <td><strong>@item.Name</strong></td>
                    <td>@item.Price.ToString("C")</td>
                    <td>
                        @if (item.Discount > 0)
                        {
                            <span class="discount-badge">-@item.Discount%</span>
                        }
                        else
                        {
                            <span class="no-discount">Нет</span>
                        }
                    </td>
                    <td>@item.StockQuantity шт.</td>
                    <td class="action-links">
                        <a href="/Admin/Edit/@item.Id">Редактировать</a> |
                        <a href="/Admin/Delete/@item.Id"
                           class="delete-link"
                           onclick="return confirm('Удалить товар?');">Удалить</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>