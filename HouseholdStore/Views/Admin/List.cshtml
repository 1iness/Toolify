@model IEnumerable<Toolify.ProductService.Models.Product>

@{
    ViewData["Title"] = "Список товаров";
    Layout = "_AdminLayout";
}

<link rel="stylesheet" href="~/css/site.css" />

<div class="admin-flush-page" data-admin-heading="Список товаров">
    <h1 class="visually-hidden">Список товаров</h1>
    <div class="admin-products-list-toolbar">
        <div class="admin-products-list-actions">
            <a href="/Admin/Create" class="btn-create">
                <i class="bi bi-plus-lg"></i> Добавить новый товар
            </a>
            <a href="/Admin/Categories" class="btn-create btn-create--secondary">
                Категории
            </a>
        </div>
    </div>

    <div class="admin-products-table-wrap">
    <table class="admin-table admin-table--products">
        <thead>
            <tr>
                <th>Id</th>
                <th>Фото</th>
                <th>Название</th>
                <th>Цена</th>
                <th style="text-align: center;">Акция</th>
                <th>Кол-во</th>
                <th>Действия</th>
            </tr>
        </thead>
        <tbody id="products-filter-tbody">
            @foreach (var item in Model)
            {
                var productSearchBlob = (item.Name ?? "").Trim().ToLowerInvariant();
                <tr data-product-search="@productSearchBlob">
                    <td>@item.Id</td>
                    <td>
                        <img src="https://localhost:7188/api/Product/@(item.Id)/image"
                             class="product-img-preview"
                             onerror="this.onerror=null; this.src='/image/no-image.png';" />
                    </td>
                    <td><strong>@item.Name</strong></td>
                    <td>@item.Price.ToString("N2") <span class="nbrb-icon">&#xE901;</span></td>
                    <td style="text-align:center;">
                        <span class="no-discount">См. правила</span>
                    </td>
                    <td>@item.StockQuantity шт.</td>
                    <td class="action-links">
                        <a href="/Admin/Edit/@item.Id">Редактировать</a> |
                        <a href="/Admin/Delete/@item.Id"
                           class="delete-link"
                           onclick="return confirm('Удалить товар?');">Удалить</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
    </div>
</div>