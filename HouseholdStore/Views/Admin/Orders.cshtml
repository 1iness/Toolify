@model IEnumerable<Toolify.ProductService.Models.Order>

@{
    ViewData["Title"] = "Управление заказами";
    Layout = "_AdminLayout";
}

<div class="orders-container py-2 px-1">

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <i class="fas fa-check-circle me-2"></i>@TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        <div class="card mb-4 admin-panel-card border-0">
            <div class="card-body bg-light rounded-top">
                <form method="get" asp-action="Orders" class="row g-3 align-items-end">
                    <div class="col-md-3">
                        <label class="form-label fw-bold text-muted small text-uppercase">Дата начала</label>
                        <input type="date" name="startDate" class="form-control" value="@ViewBag.StartDate" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label fw-bold text-muted small text-uppercase">Дата окончания</label>
                        <input type="date" name="endDate" class="form-control" value="@ViewBag.EndDate" />
                    </div>
                    <div class="col-md-6">
                        <button type="submit" class="btn btn-primary me-2">Применить фильтр</button>
                        <a href="/Admin/Orders" class="btn btn-outline-secondary"><i class="fas fa-times me-1"></i> Сбросить</a>
                    </div>
                </form>
            </div>
        </div>

        <div class="card admin-panel-card border-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead>
                        <tr>
                            <th width="8%">№ Заказа</th>
                            <th width="15%">Дата</th>
                            <th width="30%">Клиент</th>
                            <th width="12%">Сумма</th>
                            <th width="10%">Промокод</th>
                            <th width="18%">Статус</th>
                            <th width="10%" class="text-center">Действие</th>
                        </tr>
                    </thead>
                    <tbody id="orders-filter-tbody">
                        @if (Model != null && Model.Any())
                        {
                            foreach (var order in Model)
                            {
                                var guestFirst = order.GuestFirstName ?? "";
                                var guestLast = order.GuestLastName ?? "";
                                var guestMail = order.GuestEmail ?? "";
                                var orderSearchBlob = $"{guestFirst} {guestLast} {guestMail}".Trim().ToLowerInvariant();
                                <tr data-order-search="@orderSearchBlob">
                                    <td class="fw-bold text-primary">#@order.Id</td>
                                    <td>@order.OrderDate.ToString("dd.MM.yyyy HH:mm")</td>
                                    <td>
                                        <div class="client-info">
                                            <div class="client-name">@(order.GuestFirstName ?? "Зарегистрированный") @order.GuestLastName</div>
                                            <div class="client-email">@order.GuestEmail</div>
                                            @if (!string.IsNullOrEmpty(order.GuestPhone))
                                            {
                                                <div class="small text-muted">@order.GuestPhone</div>
                                            }
                                        </div>
                                    </td>
                                    <td class="fw-bold">@order.TotalAmount.ToString("N2") <span class="nbrb-icon">&#xE901;</span></td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(order.PromoCode))
                                        {
                                            <span class="badge bg-success">@order.PromoCode</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>
                                    <td>
                                        <form asp-action="UpdateOrderStatus" method="post" class="m-0">
                                            <input type="hidden" name="orderId" value="@order.Id" />
                                            @{
                                                var selectClass = "status-" + order.Status.Replace(" ", ".");
                                            }
                                            <select name="status" class="form-select status-select @selectClass" onchange="this.form.submit()">
                                                <option value="Новый" selected="@(order.Status == "Новый")">Новый</option>
                                                <option value="В обработке" selected="@(order.Status == "В обработке")">В обработке</option>
                                                <option value="Доставляется" selected="@(order.Status == "Доставляется")">Доставляется</option>
                                                <option value="Доставлен" selected="@(order.Status == "Доставлен")">Доставлен</option>
                                                <option value="Завершен" selected="@(order.Status == "Завершен")">Завершен</option>
                                                <option value="Отменен" selected="@(order.Status == "Отменен")">Отменен</option>
                                            </select>
                                        </form>
                                    </td>
                                    <td class="text-center">
                                        <button type="button" class="btn btn-sm btn-outline-info" title="Посмотреть детали">
                                            <i class="fas fa-eye"></i>
                                        </button>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="7" class="text-center py-5 text-muted">
                                    <i class="fas fa-box-open fa-3x mb-3 text-light"></i><br />
                                    В выбранном диапазоне дат заказы не найдены.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
</div>
