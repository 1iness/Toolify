@model HouseholdStore.Models.AdminReportsViewModel
@using Microsoft.AspNetCore.Html
@{
    ViewData["Title"] = "Отчеты";
    Layout = "_AdminLayout";
    var selectedSalesCategories = Model.Filter.SalesCategoryIds?.ToHashSet() ?? new HashSet<int>();
    var selectedPopularityCategories = Model.Filter.PopularityCategoryIds?.ToHashSet() ?? new HashSet<int>();
}

<style>
        .reports-root {
            background: transparent;
            color: #223;
            font-family: 'Montserrat', sans-serif;
        }
        .reports-container { max-width: 1380px; margin: 0 auto; }
        .page-header {
            background: #fff;
            border-radius: 18px;
            border: 1px solid #e8efe9;
            box-shadow: 0 10px 25px rgba(16, 60, 30, 0.08);
            padding: 18px 22px;
        }
        .page-header h2 { font-weight: 700; margin-bottom: 6px; color: #1f3828; }
        .page-header .text-muted { color: #5f7567 !important; }
        .report-section {
            border: 1px solid #e8efe9;
            border-radius: 18px;
            box-shadow: 0 10px 25px rgba(16, 60, 30, 0.08);
            overflow: hidden;
        }
        .report-section .card-header {
            background: linear-gradient(90deg, #ffffff 0%, #f5fbf5 100%) !important;
            border-bottom: 1px solid #ebf1ec;
            padding: 16px 20px;
        }
        .report-title {
            font-size: 1.06rem;
            font-weight: 700;
            color: #1f3c2b;
            margin: 0;
            display: flex;
            align-items: center;
            gap: 10px;
        }
        .report-index {
            display: inline-flex;
            width: 28px;
            height: 28px;
            border-radius: 999px;
            background: #e8f8ee;
            color: #28a745;
            align-items: center;
            justify-content: center;
            font-size: .85rem;
            font-weight: 700;
        }
        .report-subtitle {
            margin-top: 6px;
            color: #5f7567;
            font-size: .88rem;
        }
        .report-filter {
            background: #f9fcf9;
            border-bottom: 1px solid #ebf1ec;
        }
        .filter-caption {
            font-size: .78rem;
            font-weight: 700;
            letter-spacing: .06em;
            text-transform: uppercase;
            color: #4f6859;
        }
        .table thead th {
            white-space: nowrap;
            background: #f2f8f3;
            color: #2f4a38;
            font-size: .86rem;
            font-weight: 700;
        }
        .table td { vertical-align: middle; }
        .table tbody tr:hover { background: #f7fcf8; }
        .category-select { min-height: 110px; }
        .metric-value { font-size: 1.6rem; font-weight: 700; }
        .metric-value, .fw-bold { color: #1f3e2c; }
        .btn-toolify-primary {
            background: #28a745;
            border: 1px solid #28a745;
            color: #fff;
            font-weight: 600;
        }
        .btn-toolify-primary:hover {
            background: #218838;
            border-color: #218838;
            color: #fff;
        }
        .btn-toolify-outline {
            background: #fff;
            border: 1px solid #b9d4c1;
            color: #2d6a3e;
            font-weight: 600;
        }
        .btn-toolify-outline:hover {
            background: #e8f8ee;
            border-color: #28a745;
            color: #1f5a33;
        }
        .btn-back {
            border: 1px solid #d8e8dd;
            color: #2f5f40;
            background: #fff;
            font-weight: 600;
        }
        .btn-back:hover { background: #f2f9f4; color: #244f35; }
        .report-actions {
            min-height: 100%;
        }
        .btn-toolify-reset {
            border: 1px solid #d8e8dd;
            color: #5f7567;
            background: #fff;
            font-weight: 600;
            font-size: .875rem;
        }
        .btn-toolify-reset:hover {
            background: #f7fbf8;
            color: #2f5f40;
            border-color: #b9d4c1;
        }
    </style>

<div class="reports-root">
    <div class="reports-container py-4 px-3">


        <div class="card report-section mb-4">
            <div class="card-header">
                <h5 class="report-title">Отчет по продажам</h5>
                <div class="report-subtitle">Показывает продажи по категориям за период: <strong>@Model.SalesPeriodTitle</strong>. Отмененные заказы исключены.</div>
            </div>
            <div class="card-body report-filter">
                <form method="get" asp-action="Reports" class="row g-3 align-items-stretch">
                    <div class="col-12"><div class="filter-caption">Фильтр отчета</div></div>
                    <div class="d-none">
                        @RenderHiddenAverageFilter()
                        @RenderHiddenPopularityFilter()
                        @RenderHiddenCustomerFilter()
                    </div>
                    <div class="col-lg-2 col-md-4 d-flex flex-column">
                        <label class="form-label fw-bold text-muted small text-uppercase">Дата начала</label>
                        <input type="date" name="SalesStartDate" class="form-control mt-auto" value="@Model.Filter.SalesStartDate?.ToString("yyyy-MM-dd")" />
                    </div>
                    <div class="col-lg-2 col-md-4 d-flex flex-column">
                        <label class="form-label fw-bold text-muted small text-uppercase">Дата окончания</label>
                        <input type="date" name="SalesEndDate" class="form-control mt-auto" value="@Model.Filter.SalesEndDate?.ToString("yyyy-MM-dd")" />
                    </div>
                    <div class="col-lg-4 col-md-8 d-flex flex-column">
                        <label class="form-label fw-bold text-muted small text-uppercase">Категории</label>
                        <select name="SalesCategoryIds" class="form-select category-select mt-auto" multiple>
                            @foreach (var category in Model.Categories)
                            {
                                <option value="@category.Id" selected="@selectedSalesCategories.Contains(category.Id)">@category.Name</option>
                            }
                        </select>
                    </div>
                    <div class="col-lg-4 col-md-12 report-actions d-flex flex-column justify-content-end">
                        <div class="d-flex flex-wrap align-items-center gap-2">
                            <button type="submit" class="btn btn-toolify-primary">Сформировать</button>
                            @RenderExportButtons("sales")
                            <button type="button" class="btn btn-toolify-reset report-reset-filter" data-report-block="sales">Сбросить фильтр</button>
                        </div>
                    </div>
                </form>
            </div>
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead>
                        <tr>
                            <th>Категория</th>
                            <th class="text-end">Заказов</th>
                            <th class="text-end">Продано товаров</th>
                            <th class="text-end">Сумма продаж</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.SalesByCategory.Any())
                        {
                            foreach (var row in Model.SalesByCategory)
                            {
                                <tr>
                                    <td>@row.CategoryName</td>
                                    <td class="text-end">@row.OrderCount</td>
                                    <td class="text-end">@row.ItemsSold</td>
                                    <td class="text-end fw-bold">@row.SalesAmount.ToString("N2") <span class="nbrb-icon">&#xE901;</span></td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr><td colspan="4" class="text-center text-muted py-4">Данные за выбранный период отсутствуют.</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="card report-section mb-4">
            <div class="card-header">
                <h5 class="report-title">Отчет о средней сумме чека</h5>
                <div class="report-subtitle">Показывает количество заказов, суммарную выручку и средний чек за период: <strong>@Model.AverageCheckPeriodTitle</strong>.</div>
            </div>
            <div class="card-body report-filter">
                <form method="get" asp-action="Reports" class="row g-3 align-items-stretch">
                    <div class="col-12"><div class="filter-caption">Фильтр отчета</div></div>
                    <div class="d-none">
                        @RenderHiddenSalesFilter()
                        @RenderHiddenPopularityFilter()
                        @RenderHiddenCustomerFilter()
                    </div>
                    <div class="col-lg-3 col-md-4 d-flex flex-column">
                        <label class="form-label fw-bold text-muted small text-uppercase">Дата начала</label>
                        <input type="date" name="AverageCheckStartDate" class="form-control mt-auto" value="@Model.Filter.AverageCheckStartDate?.ToString("yyyy-MM-dd")" />
                    </div>
                    <div class="col-lg-3 col-md-4 d-flex flex-column">
                        <label class="form-label fw-bold text-muted small text-uppercase">Дата окончания</label>
                        <input type="date" name="AverageCheckEndDate" class="form-control mt-auto" value="@Model.Filter.AverageCheckEndDate?.ToString("yyyy-MM-dd")" />
                    </div>
                    <div class="col-lg-6 col-md-12 report-actions d-flex flex-column justify-content-end">
                        <div class="d-flex flex-wrap align-items-center gap-2">
                            <button type="submit" class="btn btn-toolify-primary">Сформировать</button>
                            @RenderExportButtons("average")
                            <button type="button" class="btn btn-toolify-reset report-reset-filter" data-report-block="average">Сбросить фильтр</button>
                        </div>
                    </div>
                </form>
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-4">
                        <div class="text-muted small text-uppercase fw-bold">Заказов</div>
                        <div class="metric-value">@Model.AverageCheck.OrderCount</div>
                    </div>
                    <div class="col-md-4">
                        <div class="text-muted small text-uppercase fw-bold">Общая сумма</div>
                        <div class="metric-value">@Model.AverageCheck.TotalAmount.ToString("N2") <span class="nbrb-icon">&#xE901;</span></div>
                    </div>
                    <div class="col-md-4">
                        <div class="text-muted small text-uppercase fw-bold">Средняя сумма чека</div>
                        <div class="metric-value">@Model.AverageCheck.AverageAmount.ToString("N2") <span class="nbrb-icon">&#xE901;</span></div>
                    </div>
                </div>
            </div>
        </div>

        <div class="card report-section mb-4">
            <div class="card-header">
                <h5 class="report-title">Популярность товаров по категориям</h5>
                <div class="report-subtitle">Показывает лидирующие товары и их продажи за период: <strong>@Model.PopularityPeriodTitle</strong>.</div>
            </div>
            <div class="card-body report-filter">
                <form method="get" asp-action="Reports" class="row g-3 align-items-stretch">
                    <div class="col-12"><div class="filter-caption">Фильтр отчета</div></div>
                    <div class="d-none">
                        @RenderHiddenSalesFilter()
                        @RenderHiddenAverageFilter()
                        @RenderHiddenCustomerFilter()
                    </div>
                    <div class="col-lg-2 col-md-4 d-flex flex-column">
                        <label class="form-label fw-bold text-muted small text-uppercase">Дата начала</label>
                        <input type="date" name="PopularityStartDate" class="form-control mt-auto" value="@Model.Filter.PopularityStartDate?.ToString("yyyy-MM-dd")" />
                    </div>
                    <div class="col-lg-2 col-md-4 d-flex flex-column">
                        <label class="form-label fw-bold text-muted small text-uppercase">Дата окончания</label>
                        <input type="date" name="PopularityEndDate" class="form-control mt-auto" value="@Model.Filter.PopularityEndDate?.ToString("yyyy-MM-dd")" />
                    </div>
                    <div class="col-lg-4 col-md-8 d-flex flex-column">
                        <label class="form-label fw-bold text-muted small text-uppercase">Категории</label>
                        <select name="PopularityCategoryIds" class="form-select category-select mt-auto" multiple>
                            @foreach (var category in Model.Categories)
                            {
                                <option value="@category.Id" selected="@selectedPopularityCategories.Contains(category.Id)">@category.Name</option>
                            }
                        </select>
                    </div>
                    <div class="col-lg-4 col-md-12 report-actions d-flex flex-column justify-content-end">
                        <div class="d-flex flex-wrap align-items-center gap-2">
                            <button type="submit" class="btn btn-toolify-primary">Сформировать</button>
                            @RenderExportButtons("popularity")
                            <button type="button" class="btn btn-toolify-reset report-reset-filter" data-report-block="popularity">Сбросить фильтр</button>
                        </div>
                    </div>
                </form>
            </div>
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead>
                        <tr>
                            <th>Категория</th>
                            <th>Товар</th>
                            <th class="text-end">Продано, шт.</th>
                            <th class="text-end">Заказов</th>
                            <th class="text-end">Сумма продаж</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.ProductPopularity.Any())
                        {
                            foreach (var row in Model.ProductPopularity)
                            {
                                <tr>
                                    <td>@row.CategoryName</td>
                                    <td>@row.ProductName</td>
                                    <td class="text-end">@row.QuantitySold</td>
                                    <td class="text-end">@row.OrderCount</td>
                                    <td class="text-end fw-bold">@row.SalesAmount.ToString("N2") <span class="nbrb-icon">&#xE901;</span></td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr><td colspan="5" class="text-center text-muted py-4">Данные за выбранный период отсутствуют.</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="card report-section mb-4">
            <div class="card-header">
                <h5 class="report-title">История покупок по покупателям</h5>
                <div class="report-subtitle">Показывает активность покупателей и динамику заказов за период: <strong>@Model.CustomerPeriodTitle</strong>.</div>
            </div>
            <div class="card-body report-filter">
                <form method="get" asp-action="Reports" class="row g-3 align-items-stretch">
                    <div class="col-12"><div class="filter-caption">Фильтр отчета</div></div>
                    <div class="d-none">
                        @RenderHiddenSalesFilter()
                        @RenderHiddenAverageFilter()
                        @RenderHiddenPopularityFilter()
                    </div>
                    <div class="col-lg-3 col-md-4 d-flex flex-column">
                        <label class="form-label fw-bold text-muted small text-uppercase">Дата начала</label>
                        <input type="date" name="CustomerStartDate" class="form-control mt-auto" value="@Model.Filter.CustomerStartDate?.ToString("yyyy-MM-dd")" />
                    </div>
                    <div class="col-lg-3 col-md-4 d-flex flex-column">
                        <label class="form-label fw-bold text-muted small text-uppercase">Дата окончания</label>
                        <input type="date" name="CustomerEndDate" class="form-control mt-auto" value="@Model.Filter.CustomerEndDate?.ToString("yyyy-MM-dd")" />
                    </div>
                    <div class="col-lg-6 col-md-12 report-actions d-flex flex-column justify-content-end">
                        <div class="d-flex flex-wrap align-items-center gap-2">
                            <button type="submit" class="btn btn-toolify-primary">Сформировать</button>
                            @RenderExportButtons("customers")
                            <button type="button" class="btn btn-toolify-reset report-reset-filter" data-report-block="customers">Сбросить фильтр</button>
                        </div>
                    </div>
                </form>
            </div>
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead>
                        <tr>
                            <th>Покупатель</th>
                            <th>Email</th>
                            <th class="text-end">Заказов</th>
                            <th class="text-end">Куплено товаров</th>
                            <th class="text-end">Общая сумма</th>
                            <th class="text-end">Средний чек</th>
                            <th>Последняя покупка</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.CustomerPurchaseHistory.Any())
                        {
                            foreach (var row in Model.CustomerPurchaseHistory)
                            {
                                <tr>
                                    <td>@row.CustomerName</td>
                                    <td>@row.Email</td>
                                    <td class="text-end">@row.OrderCount</td>
                                    <td class="text-end">@row.ItemsPurchased</td>
                                    <td class="text-end fw-bold">@row.TotalAmount.ToString("N2") <span class="nbrb-icon">&#xE901;</span></td>
                                    <td class="text-end">@row.AverageOrderAmount.ToString("N2") <span class="nbrb-icon">&#xE901;</span></td>
                                    <td>@(row.LastOrderDate?.ToString("dd.MM.yyyy") ?? "-")</td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr><td colspan="7" class="text-center text-muted py-4">Покупки за выбранный период отсутствуют.</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

    <script>
        (function () {
            var resetMap = {
                sales: { dates: ['SalesStartDate', 'SalesEndDate'], selects: ['SalesCategoryIds'] },
                average: { dates: ['AverageCheckStartDate', 'AverageCheckEndDate'], selects: [] },
                popularity: { dates: ['PopularityStartDate', 'PopularityEndDate'], selects: ['PopularityCategoryIds'] },
                customers: { dates: ['CustomerStartDate', 'CustomerEndDate'], selects: [] }
            };
            document.querySelectorAll('.report-reset-filter').forEach(function (btn) {
                btn.addEventListener('click', function () {
                    var block = btn.getAttribute('data-report-block');
                    var cfg = resetMap[block];
                    if (!cfg) return;
                    var form = btn.closest('form');
                    cfg.dates.forEach(function (name) {
                        var el = form.querySelector('input[type="date"][name="' + name + '"]');
                        if (el) el.value = '';
                    });
                    cfg.selects.forEach(function (name) {
                        form.querySelectorAll('select[name="' + name + '"] option').forEach(function (opt) {
                            opt.selected = false;
                        });
                    });
                    form.submit();
                });
            });
        })();
    </script>

@functions {
    private IHtmlContent RenderExportButtons(string reportType)
    {
        var exportUrl = Url.Action("ExportReports", "Admin");
        var html =
            "<div class=\"btn-group\" role=\"group\" aria-label=\"Экспорт отчета\">" +
            $"<button type=\"submit\" formaction=\"{exportUrl}\" name=\"format\" value=\"pdf\" class=\"btn btn-toolify-outline\"><i class=\"fas fa-file-pdf me-1\"></i>PDF</button>" +
            $"<button type=\"submit\" formaction=\"{exportUrl}\" name=\"format\" value=\"excel\" class=\"btn btn-toolify-outline\"><i class=\"fas fa-file-excel me-1\"></i>Excel</button>" +
            $"<button type=\"submit\" formaction=\"{exportUrl}\" name=\"format\" value=\"word\" class=\"btn btn-toolify-outline\"><i class=\"fas fa-file-word me-1\"></i>Word</button>" +
            $"<input type=\"hidden\" name=\"reportType\" value=\"{reportType}\" />" +
            "</div>";

        return new HtmlString(html);
    }

    private IHtmlContent RenderHiddenSalesFilter()
    {
        var html = BuildHiddenDate("SalesStartDate", Model.Filter.SalesStartDate)
            + BuildHiddenDate("SalesEndDate", Model.Filter.SalesEndDate)
            + BuildHiddenArray("SalesCategoryIds", Model.Filter.SalesCategoryIds);
        return new HtmlString(html);
    }

    private IHtmlContent RenderHiddenAverageFilter()
    {
        var html = BuildHiddenDate("AverageCheckStartDate", Model.Filter.AverageCheckStartDate)
            + BuildHiddenDate("AverageCheckEndDate", Model.Filter.AverageCheckEndDate);
        return new HtmlString(html);
    }

    private IHtmlContent RenderHiddenPopularityFilter()
    {
        var html = BuildHiddenDate("PopularityStartDate", Model.Filter.PopularityStartDate)
            + BuildHiddenDate("PopularityEndDate", Model.Filter.PopularityEndDate)
            + BuildHiddenArray("PopularityCategoryIds", Model.Filter.PopularityCategoryIds);
        return new HtmlString(html);
    }

    private IHtmlContent RenderHiddenCustomerFilter()
    {
        var html = BuildHiddenDate("CustomerStartDate", Model.Filter.CustomerStartDate)
            + BuildHiddenDate("CustomerEndDate", Model.Filter.CustomerEndDate);
        return new HtmlString(html);
    }

    private static string BuildHiddenDate(string name, DateTime? value)
    {
        return value.HasValue
            ? $"<input type=\"hidden\" name=\"{name}\" value=\"{value.Value:yyyy-MM-dd}\" />"
            : string.Empty;
    }

    private static string BuildHiddenArray(string name, IEnumerable<int>? values)
    {
        return string.Concat((values ?? Array.Empty<int>()).Select(value => $"<input type=\"hidden\" name=\"{name}\" value=\"{value}\" />"));
    }
}
