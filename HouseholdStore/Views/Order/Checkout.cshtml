@model HouseholdStore.Models.CheckoutViewModel

@{
    ViewData["Title"] = "Оформление заказа";
    ViewData["ParentPage"] = "Моя корзина";
    ViewData["ParentLink"] = Url.Action("Index", "Cart");
}

<link rel="stylesheet" href="~/css/checkout.css" />
<partial name="_Breadcrumbs" />
<div class="checkout-container py-4">
    <form asp-action="Create" method="post" id="checkoutForm">
        <div class="row checkout-grid">
            <div class="col-lg-8">

                <div class="checkout-card">
                    <h4>Заказ</h4>
                    @foreach (var item in Model.CartItems)
                    {
                        <div class="order-item-row">
                            <img src="https://localhost:7188/api/Product/@(item.ProductId)/image"
                                 alt="@item.ProductName"
                                 class="item-img"
                                 style="width: 60px; height: 60px; border-radius: 4px; margin-right: 15px;"
                                 onerror="this.onerror=null; this.src='/image/no-image.png';" />

                            <div class="item-details">
                                <div class="item-name">@item.ProductName</div>
                                <div class="item-meta">Арт. @(string.IsNullOrEmpty(item.ArticleNumber) ? "---" : item.ArticleNumber) &bull; @item.Quantity шт.</div>
                            </div>

                            <div class="item-price-block">
                                <span class="current-price">@item.TotalPrice.ToString("N2") руб</span>
                                @if (item.OldPrice.HasValue)
                                {
                                    <span class="old-price">@((item.OldPrice * item.Quantity)?.ToString("N2")) руб</span>
                                }
                            </div>
                        </div>
                    }
                </div>

                <div class="checkout-card">
                    <h4>Ваши данные</h4>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">Имя*</label>
                            <input asp-for="FirstName" class="form-control" placeholder="Имя" required />
                            <span asp-validation-for="FirstName" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Фамилия*</label>
                            <input asp-for="LastName" class="form-control" placeholder="Фамилия" required />
                            <span asp-validation-for="LastName" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Телефон*</label>
                            <input asp-for="Phone" id="phoneInput" class="form-control" placeholder="+375 (XX) XXX-XX-XX" required />
                            <span asp-validation-for="Phone" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">E-Mail*</label>
                            <input asp-for="Email" class="form-control" placeholder="Электронная почта" required />
                            <span asp-validation-for="Email" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <div class="checkout-card">
                    <h4>Способ доставки</h4>
                    <div class="mb-4">
                        <div class="form-check form-check-inline">
                            <input class="form-check-input" type="radio" name="DeliveryType" id="delCourier" value="Courier" checked onchange="toggleDelivery()">
                            <label class="form-check-label" for="delCourier">Курьером до двери</label>
                        </div>
                        <div class="form-check form-check-inline">
                            <input class="form-check-input" type="radio" name="DeliveryType" id="delPickup" value="Pickup" onchange="toggleDelivery()">
                            <label class="form-check-label" for="delPickup">Самовывоз (из пункта выдачи)</label>
                        </div>
                    </div>

                    <div id="addressFieldsBlock">
                        <h5 style="font-size: 16px; margin-bottom: 15px;">Адрес доставки</h5>
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label">Город / Нас. пункт</label>
                                <input type="text" id="CityInput" class="form-control address-part" placeholder="Минск" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Улица</label>
                                <input type="text" id="StreetInput" class="form-control address-part" placeholder="пр. Независимости" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Дом / Корпус</label>
                                <input type="text" id="HouseInput" class="form-control address-part" placeholder="11А" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Квартира / Офис</label>
                                <input type="text" id="AptInput" class="form-control address-part" placeholder="кв. 5 (оставьте пустым для частного дома)" />
                            </div>
                        </div>
                        <input type="hidden" asp-for="Address" id="FinalAddress" />
                        <span asp-validation-for="Address" class="text-danger"></span>
                    </div>
                </div>

                <div class="checkout-card">
                    <h4>Способ оплаты</h4>
                    <div class="mb-4">
                        <div class="form-check form-check-inline">
                            <input class="form-check-input" type="radio" name="PaymentType" id="payOnline" value="Online" checked onchange="togglePayment()">
                            <label class="form-check-label" for="payOnline">Картой онлайн</label>
                        </div>
                        <div class="form-check form-check-inline">
                            <input class="form-check-input" type="radio" name="PaymentType" id="payCash" value="Cash" onchange="togglePayment()">
                            <label class="form-check-label" for="payCash">При получении</label>
                        </div>
                    </div>

                    <div id="onlinePaymentFields">
                        <div class="payment-icons mb-3">
                            <span class="badge bg-light text-dark border">VISA</span>
                            <span class="badge bg-light text-dark border">MasterCard</span>
                            <span class="badge bg-light text-dark border">Белкарт</span>
                        </div>

                        <div class="row g-3">
                            <div class="col-12">
                                <label class="form-label">Номер карты</label>
                                <input asp-for="CardNumber" class="form-control" placeholder="0000 0000 0000 0000" maxlength="19" />
                                <span asp-validation-for="CardNumber" class="text-danger"></span>
                            </div>
                            <div class="col-6">
                                <label class="form-label">Срок (ММ/ГГ)</label>
                                <input asp-for="CardExpiry" class="form-control" placeholder="12/25" maxlength="5" />
                                <span asp-validation-for="CardExpiry" class="text-danger"></span>
                            </div>
                            <div class="col-6">
                                <label class="form-label">CVC/CVV</label>
                                <input asp-for="CardCvv" type="password" class="form-control" placeholder="•••" maxlength="3" />
                                <span asp-validation-for="CardCvv" class="text-danger"></span>
                            </div>
                        </div>
                    </div>
                </div>

            </div>

            <div class="col-lg-4">
                <div class="checkout-card summary-card" style="position: sticky; top: 20px;">
                    <h4>Ваш заказ</h4>

                    <div class="summary-row">
                        <span>Товары, @Model.CartItems.Sum(x => x.Quantity) шт.</span>
                        <span>@Model.TotalAmount.ToString("N2") руб</span>
                    </div>

                    @if (Model.CartItems.Any(x => x.TotalOldPrice.HasValue))
                    {
                        <div class="summary-row text-danger" style="text-decoration: line-through;">
                            <span>Без скидки</span>
                            <span>@Model.CartItems.Sum(x => x.TotalOldPrice ?? x.TotalPrice).ToString("N2") руб</span>
                        </div>
                    }

                    <div class="summary-row">
                        <span>Доставка</span>
                        <span id="summaryDeliveryText">Курьер</span>
                    </div>

                    <div class="summary-row">
                        <span>Оплата</span>
                        <span id="summaryPaymentText" class="text-success">Онлайн</span>
                    </div>

                    <hr />

                    <div class="promo-code-block mb-3">
                        <label class="form-label" style="font-size: 14px; font-weight: 600;">Есть промокод?</label>
                        <div class="input-group">
                            <input type="text" id="promoInput" class="form-control" placeholder="Введите промокод">
                            <button type="button" onclick="applyPromoCode()" class="btn-apply-promo">Применить</button>
                            <input type="hidden" asp-for="PromoCode" id="appliedPromoCode" />
                            <small id="promoStatus" class="d-block mt-1"></small>
                        </div>
                        <small id="promoStatus" class="text-muted d-block mt-1"></small>
                    </div>

                    <div class="summary-total">
                        <span>Итого:</span>
                        <span id="totalAmount" class=" total-price-large">@Model.TotalAmount.ToString("N2") руб</span>
                    </div>


                    <button type="submit" id="btnSubmitOrder" class="btn-pay" style="width: 100%; padding: 15px; font-weight: bold; background: #28a745; color: white; border-radius: 8px; border: none; margin-top: 20px;">
                        Подтвердить заказ
                    </button>
                </div>
            </div>

        </div>
    </form>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.3/jquery.validate.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/3.2.12/jquery.validate.unobtrusive.min.js"></script>

    <script>
   

    // Маски ввода  
    // тел
    const phoneInput = document.getElementById('phoneInput');
    const submitBtn = document.getElementById('btnSubmitOrder');
    const statusText = document.getElementById('phoneStatus');

    if (phoneInput) {
        phoneInput.addEventListener('input', function (e) {
            let x = e.target.value.replace(/\D/g, '').match(/(\d{0,3})(\d{0,2})(\d{0,3})(\d{0,2})(\d{0,2})/);
            if (!e.target.value.startsWith('+375')) {
                e.target.value = '+375 ';
                return;
            }
            e.target.value = !x[2] ? x[1] : '+375 (' + x[2] + (x[3] ? ') ' + x[3] : '') + (x[4] ? '-' + x[4] : '') + (x[5] ? '-' + x[5] : '');
        });
    }

    //карта
    const expiryInput = document.getElementById('CardExpiry');
    if (expiryInput) {
        expiryInput.addEventListener('input', function(e) {
            let input = e.target.value.replace(/\D/g, '');
            if (input.length > 4) input = input.substring(0, 4);

            if (input.length > 2) {
                e.target.value = input.substring(0, 2) + '/' + input.substring(2);
            } else {
                e.target.value = input;
            }
        });
    }

            // Скрываем/показываем адрес в 
        function toggleDelivery() {
            const isPickup = document.getElementById('delPickup').checked;
            const addressBlock = document.getElementById('addressFieldsBlock');
            const summaryDelivery = document.getElementById('summaryDeliveryText');

            if (isPickup) {
                addressBlock.style.display = 'none';
                summaryDelivery.textContent = 'Самовывоз (Бесплатно)';
                document.getElementById('FinalAddress').value = 'Самовывоз'; 
            } else {
                addressBlock.style.display = 'block';
                summaryDelivery.textContent = 'Курьер';
                updateFinalAddress(); 
            }
        }

        // Скрываем/показываем карту 
        function togglePayment() {
            const isCash = document.getElementById('payCash').checked;
            const paymentBlock = document.getElementById('onlinePaymentFields');
            const summaryPayment = document.getElementById('summaryPaymentText');
            const btnSubmit = document.getElementById('btnSubmitOrder');



            const cardInputs = paymentBlock.querySelectorAll('input');

            if (isCash) {
                paymentBlock.style.display = 'none';
                summaryPayment.textContent = 'При получении';
                summaryPayment.classList.replace('text-success', 'text-warning');
                btnSubmit.textContent = 'Оформить заказ';

                cardInputs.forEach(input => {
                    input.disabled = true;
                    input.value = ""; 
                });
            } else {
                paymentBlock.style.display = 'block';
                summaryPayment.textContent = 'Онлайн';
                summaryPayment.classList.replace('text-warning', 'text-success');
                btnSubmit.textContent = 'Оплатить заказ';

                cardInputs.forEach(input => {
                    input.disabled = false;
                });
            }
        }

        // Собираем адрес из кусочков перед отправкой формы
        function updateFinalAddress() {
            const city = document.getElementById('CityInput').value;
            const street = document.getElementById('StreetInput').value;
            const house = document.getElementById('HouseInput').value;
            const apt = document.getElementById('AptInput').value;

            let fullAddress = "";
            if (city) fullAddress += "г. " + city + ", ";
            if (street) fullAddress += "ул. " + street + ", ";
            if (house) fullAddress += "д. " + house;
            if (apt) fullAddress += ", кв./оф. " + apt;

            document.getElementById('FinalAddress').value = fullAddress;
        }

        document.querySelectorAll('.address-part').forEach(input => {
            input.addEventListener('input', updateFinalAddress);
        });

        document.addEventListener("DOMContentLoaded", function() {
            toggleDelivery();
            togglePayment();
        });

        document.getElementById('checkoutForm').addEventListener('submit', function(e) {
            if (document.getElementById('delCourier').checked) {
                updateFinalAddress();
                if (document.getElementById('FinalAddress').value.length < 10) {
                    e.preventDefault();
                    alert("Пожалуйста, заполните адрес доставки полностью.");
                }
            }
        });

    // номер карты
    const cardInput = document.getElementById('CardNumber');
    if (cardInput) {
        cardInput.addEventListener('input', function (e) {
            let input = e.target.value.replace(/\D/g, '');
            input = input.substring(0, 16);
            let sections = input.match(/.{1,4}/g);
            if (sections) {
                e.target.value = sections.join(' ');
            } else {
                e.target.value = input;
            }
        });
    }

            function checkPromo() {
            const code = document.getElementById('promoInput').value;
            const statusText = document.getElementById('promoStatus');

            if(!code) return;

            statusText.textContent = "Промокод будет применен при расчете итоговой суммы";
            statusText.className = "d-block mt-1 text-success";
        }

            async function applyPromoCode() {
            const codeInput = document.getElementById('promoInput');
            const statusElement = document.getElementById('promoStatus');
            const totalElement = document.getElementById('totalAmount');

            const code = codeInput.value.trim();
            if (!code) {
                statusElement.innerText = "Введите код";
                statusElement.className = "text-warning";
                return;
            }

            try {
                const response = await fetch(`/Order/ApplyPromo?code=${encodeURIComponent(code)}`, {
                    method: 'POST'
                });
                const result = await response.json();

                if (result.success) {
                     let currentTotal = parseFloat(totalElement.innerText.replace(',', '.'));
                     let discountPercent = result.discount;
                     let newTotal = currentTotal - (currentTotal * (discountPercent / 100));

                    totalElement.innerHTML = `<del class="text-muted" style="font-size: 0.8em;">${currentTotal}</del> <strong>${newTotal.toFixed(2)}</strong>`;

                    statusElement.innerText = `Скидка ${discountPercent}% применена!`;
                    statusElement.className = "text-success";

                    codeInput.readOnly = true;
                        document.getElementById('appliedPromoCode').value = code;
                } else {
                    statusElement.innerText = result.message || "Промокод не найден";
                    statusElement.className = "text-danger";
                }
            } catch (error) {
                console.error('Ошибка:', error);
                statusElement.innerText = "Ошибка при проверке промокода";
                statusElement.className = "text-danger";
            }
        }
    </script>

 }