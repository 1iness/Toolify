@model HouseholdStore.Models.CheckoutViewModel

@{
    ViewData["Title"] = "Оформление заказа";
    ViewData["ParentPage"] = "Моя корзина";
    ViewData["ParentLink"] = Url.Action("Index", "Cart");
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
<link rel="stylesheet" href="~/css/checkout.css" />
<partial name="_Breadcrumbs" />
<div class="checkout-container py-4">
    <form asp-action="Create" method="post" id="checkoutForm">
        <div class="row checkout-grid">
            <div class="col-lg-8">

                <div class="checkout-card checkout-card--order">
                    <h4 class="checkout-order-title">Заказ</h4>
                    <div class="checkout-order-preview @(Model.CartItems.Count > 3 ? "is-collapsed checkout-order-preview--many" : "")" id="checkoutOrderPreview" data-order-total="@Model.CartItems.Count">
                        <div class="checkout-order-list-wrap">
                            <div class="checkout-order-list" id="checkoutOrderList">
                                @foreach (var item in Model.CartItems)
                                {
                                    <div class="order-item-row">
                                        <img src="https://localhost:7188/api/Product/@(item.ProductId)/image"
                                             alt="@item.ProductName"
                                             class="item-img"
                                             style="width: 60px; height: 60px; border-radius: 4px; margin-right: 15px;"
                                             onerror="this.onerror=null; this.src='/image/no-image.png';" />

                                        <div class="item-details">
                                            <div class="item-name">@item.ProductName</div>
                                            <div class="item-meta">Арт. @(string.IsNullOrEmpty(item.ArticleNumber) ? "---" : item.ArticleNumber) &bull; @item.Quantity шт.</div>
                                        </div>

                                        <div class="item-price-block">
                                            <span class="current-price">@item.TotalPrice.ToString("N2") <span class="nbrb-icon">&#xE901;</span></span>
                                            @if (item.OldPrice.HasValue)
                                            {
                                                <span class="old-price">@((item.OldPrice * item.Quantity)?.ToString("N2")) <span class="nbrb-icon">&#xE901;</span></span>
                                            }
                                        </div>
                                    </div>
                                }
                            </div>
                            @if (Model.CartItems.Count > 3)
                            {
                                <div class="checkout-order-fade" id="checkoutOrderFade"></div>
                            }
                        </div>
                        @if (Model.CartItems.Count > 3)
                        {
                            <div class="checkout-order-toggle-wrap">
                                <button type="button" class="btn-checkout-order-toggle" id="checkoutOrderToggle">
                                    <span class="btn-checkout-order-toggle__label"></span>
                                    <i class="bi bi-chevron-right btn-checkout-order-toggle__chev" aria-hidden="true"></i>
                                </button>
                            </div>
                        }
                    </div>
                </div>

                <div class="checkout-card checkout-card--customer">
                    <h4 class="checkout-order-title">Ваши данные</h4>
                    <div class="checkout-customer-grid">
                        <div class="row g-3">
                            <div class="col-12 col-md-4">
                                <label class="form-label" for="@Html.IdFor(m => m.LastName)">Фамилия <span class="label-req" aria-hidden="true">*</span></label>
                                <input asp-for="LastName" class="form-control" placeholder="Фамилия" required />
                                <span asp-validation-for="LastName" class="text-danger"></span>
                            </div>
                            <div class="col-12 col-md-4">
                                <label class="form-label" for="@Html.IdFor(m => m.FirstName)">Имя <span class="label-req" aria-hidden="true">*</span></label>
                                <input asp-for="FirstName" class="form-control" placeholder="Имя" required />
                                <span asp-validation-for="FirstName" class="text-danger"></span>
                            </div>
                            <div class="col-12 col-md-4">
                                <label class="form-label" for="@Html.IdFor(m => m.Email)">E-Mail <span class="label-req" aria-hidden="true">*</span></label>
                                <input asp-for="Email" class="form-control" placeholder="Электронная почта" required />
                                <span asp-validation-for="Email" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="row g-3 mt-0 pt-md-1">
                            <div class="col-12 col-md-6">
                                <label class="form-label" for="phoneInput">Телефон <span class="label-req" aria-hidden="true">*</span></label>
                                <input asp-for="Phone" id="phoneInput" class="form-control" placeholder="+375 (XX) XXX-XX-XX" required />
                                <span asp-validation-for="Phone" class="text-danger"></span>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="checkout-card checkout-card--delivery">
                    <h4 class="checkout-order-title">Способ доставки</h4>
                    <div class="mb-4">
                        <div class="form-check form-check-inline">
                            <input class="form-check-input" type="radio" asp-for="DeliveryType" id="delCourier" value="Courier" onchange="toggleDelivery(); recalcCheckoutTotals();">
                            <label class="form-check-label" for="delCourier">Курьером до двери</label>
                        </div>
                        <div class="form-check form-check-inline">
                            <input class="form-check-input" type="radio" asp-for="DeliveryType" id="delPickup" value="Pickup" onchange="toggleDelivery(); recalcCheckoutTotals();">
                            <label class="form-check-label" for="delPickup">Самовывоз (из пункта выдачи)</label>
                        </div>
                    </div>
                    <div id="addressFieldsBlock">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label">Город / Нас. пункт</label>
                                <input type="text" id="CityInput" class="form-control address-part" placeholder="Минск" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Улица</label>
                                <input type="text" id="StreetInput" class="form-control address-part" placeholder="пр. Независимости" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Дом / Корпус</label>
                                <input type="text" id="HouseInput" class="form-control address-part" placeholder="11А" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Квартира / Офис</label>
                                <input type="text" id="AptInput" class="form-control address-part" placeholder="кв. 5 (оставьте пустым для частного дома)" />
                            </div>
                        </div>
                        <input type="hidden" asp-for="Address" id="FinalAddress" />
                        <span asp-validation-for="Address" class="text-danger"></span>
                    </div>
                </div>

                <div class="checkout-card">
                    <h4>Способ оплаты</h4>
                    <p class="text-muted small mb-3">Оплата при получении заказа</p>
                    <div class="mb-2">
                        <div class="form-check mb-2">
                            <input class="form-check-input" type="radio" asp-for="PaymentMethod" id="payCardDelivery" value="CardOnDelivery" onchange="recalcCheckoutTotals()">
                            <label class="form-check-label" for="payCardDelivery">Картой при получении</label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="radio" asp-for="PaymentMethod" id="payCashDelivery" value="CashOnDelivery" onchange="recalcCheckoutTotals()">
                            <label class="form-check-label" for="payCashDelivery">Наличными при получении</label>
                        </div>
                    </div>
                </div>

            </div>

            <div class="col-lg-4">
                <div class="checkout-card summary-card checkout-summary-card" style="position: sticky; top: 20px;">
                    <h4 class="checkout-order-title">Ваш заказ</h4>

                    <div id="checkoutPricing"
                         data-base-goods="@Model.TotalAmount.ToString(System.Globalization.CultureInfo.InvariantCulture)"
                         data-threshold="@CheckoutViewModel.FreeDeliveryThreshold.ToString(System.Globalization.CultureInfo.InvariantCulture)"
                         data-fee="@CheckoutViewModel.CourierDeliveryFee.ToString(System.Globalization.CultureInfo.InvariantCulture)"
                         data-qty="@Model.CartItems.Sum(x => x.Quantity)"
                         hidden></div>
                    <input type="hidden" id="appliedPromoPercent" value="0" />

                    <div class="summary-row">
                        <div class="summary-row__label-stack">
                            <span class="summary-row__heading">Товары</span>
                            <span class="summary-row__sub"><span id="summaryQtyLabel">@Model.CartItems.Sum(x => x.Quantity)</span> шт.</span>
                        </div>
                        <span id="summaryGoodsAmount" class="summary-row__value summary-row__value--goods">@Model.TotalAmount.ToString("N2") <span class="nbrb-icon">&#xE901;</span></span>
                    </div>

                    @if (Model.CartItems.Any(x => x.TotalOldPrice.HasValue))
                    {
                        <div class="summary-row summary-row--strike">
                            <span class="summary-row__heading">Цена без скидки</span>
                            <span class="summary-row__value summary-row__value--old-price">@Model.CartItems.Sum(x => x.TotalOldPrice ?? x.TotalPrice).ToString("N2") <span class="nbrb-icon">&#xE901;</span></span>
                        </div>
                    }

                    <div class="summary-row" id="summaryPromoRow" style="display: none;">
                        <span class="summary-row__heading">Промокод</span>
                        <span id="summaryPromoText" class="summary-row__value summary-row__value--promo"></span>
                    </div>

                    <div class="summary-row checkout-discounts-note">
                        <div class="summary-row__label-stack">
                            <span class="summary-row__heading">Скидки по акции / клиенту</span>
                            <span class="summary-row__sub">Процент и фиксированная сумма по правилам магазина считаются при подтверждении заказа на сервере; сумма выше — по товарам в корзине (и промокод, если указан).</span>
                        </div>
                    </div>

                    <div class="summary-row summary-row--delivery">
                        <span class="summary-row__heading">Доставка</span>
                        <span id="summaryDeliverySummary" class="summary-row__value summary-delivery-value">—</span>
                    </div>

                    <div class="summary-row">
                        <span class="summary-row__heading">Оплата</span>
                        <span id="summaryPaymentText" class="summary-row__value summary-row__payment">Картой при получении</span>
                    </div>

                    <hr />

                    <div class="promo-code-block mb-3">
                        <label class="form-label" style="font-size: 14px; font-weight: 600;">Есть промокод?</label>
                        <div class="input-group">
                            <input type="text" id="promoInput" class="form-control" placeholder="Введите промокод">
                            <input type="hidden" asp-for="PromoCode" id="appliedPromoCode" />
                        </div>
                        <small id="promoStatus" class="d-block mt-1 text-muted"></small>
                    </div>

                    <div class="summary-total">
                        <span>Итого:</span>
                        <span id="totalAmount" class="total-price-large">@Model.TotalAmount.ToString("N2") <span class="nbrb-icon">&#xE901;</span></span>
                    </div>

                    <button type="submit" id="btnSubmitOrder" class="btn-pay" style="width: 100%; padding: 15px; font-weight: bold; background: #28a745; color: white; border-radius: 8px; border: none; margin-top: 20px;">
                        Подтвердить заказ
                    </button>
                </div>
            </div>

        </div>
    </form>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.3/jquery.validate.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/3.2.12/jquery.validate.unobtrusive.min.js"></script>

    <script>


        // Маски ввода
        // тел
        const phoneInput = document.getElementById('phoneInput');
        const submitBtn = document.getElementById('btnSubmitOrder');
        const statusText = document.getElementById('phoneStatus');

        if (phoneInput) {
            phoneInput.addEventListener('input', function (e) {
                let x = e.target.value.replace(/\D/g, '').match(/(\d{0,3})(\d{0,2})(\d{0,3})(\d{0,2})(\d{0,2})/);
                if (!e.target.value.startsWith('+375')) {
                    e.target.value = '+375 ';
                    return;
                }
                e.target.value = !x[2] ? x[1] : '+375 (' + x[2] + (x[3] ? ') ' + x[3] : '') + (x[4] ? '-' + x[4] : '') + (x[5] ? '-' + x[5] : '');
            });
        }

            const BYN_HTML = '<span class="nbrb-icon">&#xE901;</span>';
            function formatCheckoutMoneyHtml(n) {
                return n.toFixed(2).replace('.', ',') + ' ' + BYN_HTML;
            }

            function recalcCheckoutTotals() {
                const cfg = document.getElementById('checkoutPricing');
                if (!cfg) return;
                const base = parseFloat(cfg.dataset.baseGoods || '0');
                const threshold = parseFloat(cfg.dataset.threshold || '50');
                const courierFee = parseFloat(cfg.dataset.fee || '4.5');
                const promoEl = document.getElementById('appliedPromoPercent');
                const promoPct = promoEl ? (parseFloat(promoEl.value) || 0) : 0;
                const goodsAfterPromo = base * (1 - promoPct / 100);
                const courier = document.getElementById('delCourier') && document.getElementById('delCourier').checked;
                let deliveryFee = 0;
                let deliverySummary = '';
                if (!courier) {
                    deliverySummary = 'Самовывоз';
                } else if (goodsAfterPromo > threshold) {
                    deliverySummary = 'Курьер, бесплатно';
                } else {
                    deliveryFee = courierFee;
                    deliverySummary = 'Курьер +' + courierFee.toFixed(2).replace('.', ',') + '\u00A0' + BYN_HTML;
                }

        const goodsEl = document.getElementById('summaryGoodsAmount');
                        const delSummaryEl = document.getElementById('summaryDeliverySummary');
                        const totalEl = document.getElementById('totalAmount');
                        if (goodsEl) goodsEl.innerHTML = formatCheckoutMoneyHtml(goodsAfterPromo);
                        if (delSummaryEl) delSummaryEl.innerHTML = deliverySummary;
                        if (totalEl) totalEl.innerHTML = formatCheckoutMoneyHtml(goodsAfterPromo + deliveryFee);

                const promoRow = document.getElementById('summaryPromoRow');
                const promoText = document.getElementById('summaryPromoText');
                if (promoRow && promoText) {
                    if (promoPct > 0) {
                        promoRow.style.display = 'flex';
                        promoText.textContent = '−' + promoPct + '%';
                    } else {
                        promoRow.style.display = 'none';
                    }
                }

                const payEl = document.getElementById('summaryPaymentText');
                const cardPay = document.getElementById('payCardDelivery');
                if (payEl && cardPay) {
                    payEl.textContent = cardPay.checked ? 'Картой при получении' : 'Наличными при получении';
                }
            }

            function toggleDelivery() {
                const isPickup = document.getElementById('delPickup').checked;
                const addressBlock = document.getElementById('addressFieldsBlock');

                if (isPickup) {
                    addressBlock.style.display = 'none';
                    document.getElementById('FinalAddress').value = 'Самовывоз';
                } else {
                    addressBlock.style.display = 'block';
                    updateFinalAddress();
                }
            }

            // Собираем адрес из кусочков перед отправкой формы
            function updateFinalAddress() {
                const city = document.getElementById('CityInput').value;
                const street = document.getElementById('StreetInput').value;
                const house = document.getElementById('HouseInput').value;
                const apt = document.getElementById('AptInput').value;

                let fullAddress = "";
                if (city) fullAddress += "г. " + city + ", ";
                if (street) fullAddress += "ул. " + street + ", ";
                if (house) fullAddress += "д. " + house;
                if (apt) fullAddress += ", кв./оф. " + apt;

                document.getElementById('FinalAddress').value = fullAddress;
            }

            document.querySelectorAll('.address-part').forEach(input => {
                input.addEventListener('input', updateFinalAddress);
            });

            function initCheckoutOrderToggle() {
                const preview = document.getElementById('checkoutOrderPreview');
                const btn = document.getElementById('checkoutOrderToggle');
                if (!preview || !btn) return;

                const labelEl = btn.querySelector('.btn-checkout-order-toggle__label');
                const iconEl = btn.querySelector('.btn-checkout-order-toggle__chev');
                if (!labelEl) return;

                const total = parseInt(preview.dataset.orderTotal || '0', 10);
                const maxVisible = 3;
                if (total <= maxVisible) return;

                let expanded = false;
                const hiddenCount = total - maxVisible;

                function tovarForm(n) {
                    const n100 = n % 100;
                    const n10 = n % 10;
                    if (n100 >= 11 && n100 <= 14) return 'товаров';
                    if (n10 === 1) return 'товар';
                    if (n10 >= 2 && n10 <= 4) return 'товара';
                    return 'товаров';
                }

                function update() {
                    preview.classList.toggle('is-collapsed', !expanded);
                    preview.classList.toggle('is-expanded', expanded);
                    if (expanded) {
                        labelEl.textContent = 'Свернуть';
                        if (iconEl) {
                            iconEl.className = 'bi bi-chevron-up btn-checkout-order-toggle__chev';
                        }
                    } else {
                        labelEl.textContent = 'В корзине ещё ' + hiddenCount + ' ' + tovarForm(hiddenCount);
                        if (iconEl) {
                            iconEl.className = 'bi bi-chevron-right btn-checkout-order-toggle__chev';
                        }
                    }
                }

                btn.addEventListener('click', function () {
                    expanded = !expanded;
                    update();
                });
                update();
            }

            document.addEventListener("DOMContentLoaded", function() {
                toggleDelivery();
                recalcCheckoutTotals();
                initCheckoutOrderToggle();
                initPromoAutoApply();
            });

            document.getElementById('checkoutForm').addEventListener('submit', function(e) {
                if (document.getElementById('delCourier').checked) {
                    updateFinalAddress();
                    if (document.getElementById('FinalAddress').value.length < 10) {
                        e.preventDefault();
                        alert("Пожалуйста, заполните адрес доставки полностью.");
                    }
                }
            });

                       function setPromoUiState(state, payload) {
                const codeInput = document.getElementById('promoInput');
                const statusElement = document.getElementById('promoStatus');
                if (!codeInput || !statusElement) return;

                codeInput.classList.remove('promo-input--valid', 'promo-input--invalid');

                if (state === 'idle') {
                    statusElement.textContent = '';
                    statusElement.className = 'd-block mt-1 text-muted';
                    return;
                }

                if (state === 'valid') {
                    const discount = payload?.discount ?? 0;
                    codeInput.classList.add('promo-input--valid');
                    statusElement.textContent = `Скидка ${discount}%`;
                    statusElement.className = 'd-block mt-1 promo-status--valid';
                    return;
                }

                if (state === 'invalid') {
                    const code = payload?.code ?? '';
                    codeInput.classList.add('promo-input--invalid');
                    statusElement.textContent = code ? `${code} — промокод отсутствует или истёк.` : 'Промокод отсутствует или истёк.';
                    statusElement.className = 'd-block mt-1 promo-status--invalid';
                    return;
                }
            }

            function clearAppliedPromo() {
                const promoPct = document.getElementById('appliedPromoPercent');
                const promoCodeHidden = document.getElementById('appliedPromoCode');
                if (promoPct) promoPct.value = '0';
                if (promoCodeHidden) promoCodeHidden.value = '';
            }

            let promoLastChecked = '';
            async function applyPromoCodeIfNeeded() {
                const codeInput = document.getElementById('promoInput');
                const code = (codeInput?.value ?? '').trim();

                if (!code) {
                    promoLastChecked = '';
                    clearAppliedPromo();
                    setPromoUiState('idle');
                    recalcCheckoutTotals();
                    return;
                }

                if (code.toLowerCase() === promoLastChecked.toLowerCase()) return;
                promoLastChecked = code;

                try {
                    const cfg = document.getElementById('checkoutPricing');
                    const baseGoods = cfg ? (parseFloat(cfg.dataset.baseGoods || '0') || 0) : 0;
                    const response = await fetch('/Order/ApplyPromo?code=' + encodeURIComponent(code) + '&goodsTotal=' + encodeURIComponent(baseGoods.toString()), { method: 'POST' });
                    const result = await response.json();

                    if (result.success) {
                        document.getElementById('appliedPromoPercent').value = result.discount;
                        document.getElementById('appliedPromoCode').value = code;
                        setPromoUiState('valid', { discount: result.discount });
                        recalcCheckoutTotals();
                    } else {
                        clearAppliedPromo();
                        setPromoUiState('invalid', { code });
                        recalcCheckoutTotals();
                    }
                } catch (error) {
                    console.error('Ошибка:', error);
                    clearAppliedPromo();
                    setPromoUiState('invalid', { code });
                    recalcCheckoutTotals();
                }
            }

            function initPromoAutoApply() {
                const codeInput = document.getElementById('promoInput');
                if (!codeInput) return;

                codeInput.addEventListener('blur', function () {
                    applyPromoCodeIfNeeded();
                });

                codeInput.addEventListener('input', function () {
                    promoLastChecked = '';
                    setPromoUiState('idle');
                });
            }
    </script>

}