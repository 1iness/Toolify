@using System.Security.Claims
@{
    var panelKey = ViewBag.AdminPanelKey as string ?? "home";
    var email = User?.FindFirstValue(ClaimTypes.Email)
        ?? User?.FindFirstValue(ClaimTypes.Name);
    var adminShortName = email;
    if (!string.IsNullOrEmpty(email) && email.Contains('@', StringComparison.Ordinal))
        adminShortName = email.Split('@')[0];
}
<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Toolify</title>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
    <link rel="stylesheet" href="~/css/nbrb-currency.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/list.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/create-product.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/orders.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/dashboard.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/promocodes.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/admin-clients.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/chat-admin.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/admin-shell.css" asp-append-version="true" />
</head>
<body class="admin-shell-body" data-initial-panel="@panelKey" data-search-target="@(ViewBag.AdminSearchTarget as string ?? "none")">
    <div id="admin-shell-overlay" class="admin-shell-overlay" aria-hidden="true"></div>

    <div class="admin-shell">
        <aside id="admin-sidebar" class="admin-sidebar">
            <div class="admin-sidebar-brand">
                <a asp-controller="Home" asp-action="Index" class="admin-brand-link" title="На витрину">
                    <img src="~/image/logo.jpg" alt="" width="40" height="40" class="admin-brand-logo" />
                    <span>Toolify</span>
                </a>
            </div>

            <nav class="admin-sidebar-nav" aria-label="Админ-меню">
                <a href="@Url.Action("Index", "Admin")" class="admin-nav-item" data-admin-panel="home">
                    <i class="bi bi-house-door"></i><span>Главная</span>
                </a>

                <div class="admin-nav-group">
                    <a href="@Url.Action("List", "Admin")" class="admin-nav-item" data-admin-panel="products-list">
                        <i class="bi bi-grid-3x3-gap"></i><span>Список товаров</span>
                    </a>
                    <div class="admin-nav-sub">
                        <a href="@Url.Action("Categories", "Admin")" class="admin-nav-sub-item" data-admin-panel="products-categories">Категории</a>
                        <a href="@Url.Action("Create", "Admin")" class="admin-nav-sub-item" data-admin-panel="products-create">Добавить товар</a>
                    </div>
                </div>

                <a href="@Url.Action("PromoCodes", "Admin")" class="admin-nav-item" data-admin-panel="promocodes">
                    <i class="bi bi-ticket-perforated"></i><span>Создать промокод</span>
                </a>
                <a href="@Url.Action("Promotions", "Admin")" class="admin-nav-item" data-admin-panel="promotions">
                    <i class="bi bi-megaphone"></i><span>Акции</span>
                </a>
                <a href="@Url.Action("Discounts", "Admin")" class="admin-nav-item" data-admin-panel="discounts">
                    <i class="bi bi-percent"></i><span>Скидки</span>
                </a>

                <div class="admin-nav-group">
                    <a href="@Url.Action("Orders", "Admin")" class="admin-nav-item" data-admin-panel="orders">
                        <i class="bi bi-receipt-cutoff"></i><span>Учёт заказов</span>
                    </a>
                    <div class="admin-nav-sub">
                        <a href="@Url.Action("Reports", "Admin")" class="admin-nav-sub-item" data-admin-panel="reports">Отчёты</a>
                    </div>
                </div>

                <a href="@Url.Action("Dashboard", "Admin")" class="admin-nav-item" data-admin-panel="dashboard">
                    <i class="bi bi-graph-up-arrow"></i><span>Общая статистика</span>
                </a>
                <a href="@Url.Action("Admin", "Chat")" class="admin-nav-item" data-admin-panel="chat">
                    <i class="bi bi-chat-dots"></i><span>Чат с клиентами</span>
                </a>
                <a href="@Url.Action("Clients", "Admin")" class="admin-nav-item" data-admin-panel="clients">
                    <i class="bi bi-people"></i><span>Клиенты</span>
                </a>
            </nav>

            <div class="admin-sidebar-footer">
                <a asp-controller="Home" asp-action="Index" class="admin-footer-store"><i class="bi bi-shop-window"></i> На сайт</a>
            </div>
        </aside>

        <div class="admin-shell-main">
            <header class="admin-topbar">
                <button type="button" id="admin-sidebar-toggle" class="admin-sidebar-toggle" aria-label="Открыть меню">
                    <i class="bi bi-list"></i>
                </button>
                <div class="admin-topbar-text">
                    <div class="admin-greeting">Добро пожаловать, <strong>@adminShortName</strong>!</div>
                    <div class="admin-page-heading">@(ViewBag.AdminSectionTitle as string ?? ViewData["Title"])</div>
                </div>
                <div class="admin-topbar-actions">
                    <div id="admin-header-search-wrap" class="admin-header-search-wrap d-none">
                        <label class="visually-hidden" for="admin-header-search">Поиск</label>
                        <i class="bi bi-search admin-header-search-icon"></i>
                        <input type="search" id="admin-header-search" class="admin-header-search" autocomplete="off" placeholder="Поиск по странице…" />
                    </div>
                    <a href="@Url.Action("Admin", "Chat")" class="admin-bell-link" title="Чаты" id="admin-chat-bell-link">
                        <i class="bi bi-bell"></i>
                        <span id="admin-chat-badge" class="admin-chat-badge d-none">0</span>
                    </a>
                </div>
            </header>

            <main id="admin-panel-root" class="admin-panel-root @(panelKey == "chat" ? "" : "admin-panel-root--wide")">
                @RenderBody()
            </main>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="~/js/admin-shell.js" asp-append-version="true"></script>
    @if (TempData["ToastMessage"] != null)
    {
        <script>
            document.addEventListener('DOMContentLoaded', function () {
                if (typeof Swal !== 'undefined') {
                    Swal.fire({
                        toast: true,
                        position: 'top-end',
                        icon: '@TempData["ToastType"]',
                        title: @Html.Raw(Json.Serialize(TempData["ToastMessage"]?.ToString())),
                        showConfirmButton: false,
                        timer: 3200,
                        timerProgressBar: true
                    });
                }
            });
        </script>
    }
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
