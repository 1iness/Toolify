@model HouseholdStore.Models.UserProfileViewModel
@{
    ViewData["Title"] = "Личный кабинет";
}

<link rel="stylesheet" href="~/css/profile.css" />

<partial name="_Breadcrumbs" />
<div class="profile-container" data-profile-tab="@(ViewBag.ProfileTab as string ?? "")">

    <aside class="profile-sidebar">
        <div class="user-brief">
            <div class="user-avatar-large"></div>
            <div class="brief-name">@Model.FirstName @Model.LastName</div>
            <div class="brief-email">@Model.Email</div>
            @if (User.IsInRole("Admin"))
            {
                <div style="margin-top: 10px;">
                    <span style="background:#fff3cd; color:#856404; font-size:12px;
                                 font-weight:700; padding:4px 12px; border-radius:20px;
                                 border:1px solid #ffc107;">
                        Администратор
                    </span>
                </div>
            }
        </div>

        <ul class="profile-menu">
            <li class="menu-item active" data-tab="personal">
                <span class="menu-icon"></span> Личные данные
            </li>
            <li class="menu-item" data-tab="orders">
                <span class="menu-icon"></span> Текущие заказы
            </li>
            <li class="menu-item" data-tab="history">
                <span class="menu-icon"></span> История заказов
            </li>
            <li class="menu-item" data-tab="favourites">
                <span class="menu-icon"></span> Избранное
            </li>
        </ul>

        @if (User.IsInRole("Admin"))
        {
            <a asp-controller="Admin" asp-action="Index" class="admin-panel-btn">
                Админ панель
            </a>
        }


        <form asp-action="Logout" method="post">
            <button type="submit" class="logout-btn">Выйти из аккаунта</button>
        </form>
    </aside>

    <main class="profile-content">
        <section id="tab-personal" class="profile-section">
            <h2 class="section-title">Личные данные</h2>

            @*просмотр*@
            <div id="view-mode">
                <div class="personal-grid">
                    <div class="info-group">
                        <label>Имя</label>
                        <input type="text" value="@Model.FirstName" class="form-input" readonly>
                    </div>
                    <div class="info-group">
                        <label>Фамилия</label>
                        <input type="text" value="@Model.LastName" class="form-input" readonly>
                    </div>
                    <div class="info-group">
                        <label>Электронная почта</label>
                        <input type="email" value="@Model.Email" class="form-input" readonly>
                    </div>
                    <div class="info-group">
                        <label>Телефон</label>
                        <input type="text" value="@Model.Phone" class="form-input" readonly>
                    </div>
                </div>
                <button type="button" class="save-changes-btn" onclick="enableEdit()">
                    Редактировать данные
                </button>
            </div>

            @*редактирование личных данных *@
            <div id="edit-mode" style="display:none;">
                <form asp-action="UpdateProfile" method="post">
                    <div class="personal-grid">
                        <div class="info-group">
                            <label>Имя</label>
                            <input type="text" name="FirstName" value="@Model.FirstName" class="form-input" required>
                        </div>
                        <div class="info-group">
                            <label>Фамилия</label>
                            <input type="text" name="LastName" value="@Model.LastName" class="form-input" required>
                        </div>
                        <div class="info-group">
                            <label>Электронная почта</label>
                            <input type="email" value="@Model.Email" class="form-input" readonly
                                   title="Email изменить нельзя">
                        </div>
                        <div class="info-group">
                            <label>Телефон</label>
                            <input type="text" name="Phone" value="@Model.Phone" class="form-input"
                                   placeholder="+375(__) ___-__-__">
                        </div>
                    </div>
                    <div style="display:flex; gap:15px; margin-top:10px;">
                        <button type="submit" class="save-changes-btn">Сохранить</button>
                        <button type="button" class="save-changes-btn"
                                style="background:#fff; color:#333; border:1px solid #ddd;"
                                onclick="cancelEdit()">
                            Отмена
                        </button>
                    </div>
                </form>
            </div>
        </section>

        <section id="tab-orders" class="profile-section" style="display: none;">
            <h2 class="section-title">Текущие заказы</h2>

            @if (Model.Orders != null && Model.Orders.Any(o => o.Status == "Новый" || o.Status == "В обработке" || o.Status == "Доставляется"))
            {
                <div class="orders-scroll-container">
                    @foreach (var order in Model.Orders.Where(o => o.Status == "Новый" || o.Status == "В обработке" || o.Status == "Доставляется"))
                    {
                        <div class="order-card-item">

                            <div class="order-card-header">
                                <div class="order-card-meta">
                                    <span class="order-number">Заказ №@order.OrderId</span>
                                    <span class="order-date">от @order.OrderDate.ToString("dd.MM.yyyy")</span>
                                </div>
                                @{
                                    var statusColor = order.Status switch
                                    {
                                        "Новый" => "#17a2b8",
                                        "В обработке" => "#ffc107",
                                        "Доставляется" => "#28a745",
                                        _ => "#6c757d"
                                    };
                                }
                                <span class="order-status-badge" style="background: @(statusColor)1a; color: @statusColor; border: 1px solid @statusColor;">
                                    @order.Status
                                </span>
                            </div>

                            <div class="order-progress">
                                <div class="progress-step @(true ? "done" : "")">
                                    <div class="step-dot"><i class="bi bi-check-lg"></i></div>
                                    <span>Оформлен</span>
                                </div>
                                <div class="progress-line @(order.Status == "В обработке" || order.Status == "Доставляется" ? "done" : "")"></div>
                                <div class="progress-step @(order.Status == "В обработке" || order.Status == "Доставляется" ? "done" : "")">
                                    <div class="step-dot"><i class="bi bi-gear"></i></div>
                                    <span>Обработка</span>
                                </div>
                                <div class="progress-line @(order.Status == "Доставляется" ? "done" : "")"></div>
                                <div class="progress-step @(order.Status == "Доставляется" ? "done" : "")">
                                    <div class="step-dot"><i class="bi bi-truck"></i></div>
                                    <span>Доставка</span>
                                </div>
                                <div class="progress-line"></div>
                                <div class="progress-step">
                                    <div class="step-dot"><i class="bi bi-house-check"></i></div>
                                    <span>Доставлен</span>
                                </div>
                            </div>

                            <div class="order-items-list">
                                @foreach (var item in order.Items)
                                {
                                    <div class="order-item-row">
                                        <img src="https://localhost:7188/api/Product/@(item.ProductId)/image"
                                             onerror="this.src='/image/no-image.png'" />
                                        <div class="order-item-info">
                                            <div class="order-item-name">@item.ProductName</div>
                                            <div class="order-item-qty">@item.Quantity шт. × @item.Price.ToString("N2") <span class="nbrb-icon">&#xE901;</span></div>
                                        </div>
                                        <div class="order-item-total">
                                            <span>@((item.Quantity * item.Price).ToString("N2")) <span class="nbrb-icon">&#xE901;</span></span>
                                        </div>
                                    </div>
                                }
                            </div>

                            <div class="order-card-footer">
                                <span>Итого по заказу:</span>
                                <span class="order-total-price">@order.TotalAmount.ToString("N2") <span class="nbrb-icon">&#xE901;</span></span>
                            </div>

                        </div>
                    }
                </div>
            }
            else
            {
                <div class="orders-empty-state">
                    <i class="bi bi-bag-x" style="font-size:48px; color:#ddd; display:block; margin-bottom:15px;"></i>
                    <p>Активных заказов нет</p>
                    <a asp-controller="Home" asp-action="Index" class="go-to-catalog">Перейти в каталог</a>
                </div>
            }
        </section>

    <section id="tab-history" class="profile-section" style="display: none;">
        <h2 class="section-title">История заказов</h2>

        @if (Model.Orders != null && Model.Orders.Any(o => o.Status == "Доставлен" || o.Status == "Отменен" || o.Status == "Завершен"))
        {
            <div class="orders-scroll-container">
                @foreach (var order in Model.Orders.Where(o => o.Status == "Доставлен" || o.Status == "Отменен" || o.Status == "Завершен"))
                {

                            var histColor = order.Status switch
                            {
                                "Отменен" => "#ff4d4f",
                                "Завершен" => "#28a745",
                                _ => "#6c757d"
                            };
                
                    <div class="order-card-item" style="opacity:0.9;">

                        <div class="order-card-header">
                            <div class="order-card-meta">
                                <span class="order-number">Заказ №@order.OrderId</span>
                                <span class="order-date">от @order.OrderDate.ToString("dd.MM.yyyy")</span>
                            </div>
                            <span class="order-status-badge"
                                  style="background:@(histColor)1a; color:@histColor; border:1px solid @histColor;">
                                @order.Status
                            </span>
                        </div>

                        <div class="order-items-list">
                            @foreach (var item in order.Items)
                            {
                                <div class="order-item-row">
                                    <img src="https://localhost:7188/api/Product/@(item.ProductId)/image"
                                         onerror="this.src='/image/no-image.png'" />
                                    <div class="order-item-info">
                                        <div class="order-item-name">@item.ProductName</div>
                                        <div class="order-item-qty">@item.Quantity шт.</div>
                                    </div>
                                    <div class="order-item-total">
                                            @((item.Quantity * item.Price).ToString("N2")) <span class="nbrb-icon">&#xE901;</span>
                                    </div>
                                </div>
                            }
                        </div>

                        <div class="order-card-footer">
                            <span>Сумма заказа:</span>
                                <span class="order-total-price">@order.TotalAmount.ToString("N2") <span class="nbrb-icon">&#xE901;</span></span>
                        </div>

                    </div>
                }
            </div>
        }
        else
        {
            <div class="orders-empty-state">
                <i class="bi bi-clock-history" style="font-size:48px; color:#ddd; display:block; margin-bottom:15px;"></i>
                <p>История заказов пуста</p>
            </div>
        }
    </section>

        <section id="tab-favourites" class="profile-section" style="display:none;">
            <h2 class="section-title">Избранное</h2>
            <div class="favourites-scroll-container">
                <div id="favourites-grid" class="favourites-grid">
                    <div style="text-align:center; padding:40px; color:#aaa;">
                        <i class="bi bi-heart" style="font-size:48px; display:block; margin-bottom:15px;"></i>
                        <p></p>
                    </div>
                </div>
            </div>
        </section>
    </main>
</div>

@section Scripts {
    <script src="~/js/profile.js"></script>
}
